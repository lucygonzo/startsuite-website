  <script is:inline>
    (function () {
      var btn = document.getElementById('pa-copy-btn');
      var src = document.getElementById('pa-release-plaintext');
      if (!btn || !src) return;
      var defaultLabel = btn.dataset.default || btn.textContent.trim();
      var copiedLabel = btn.dataset.copied || 'Copied';
      var resetTimer = null;

      btn.addEventListener('click', function () {
        var text = (src.textContent || '').trim();
        var done = function () {
          btn.textContent = copiedLabel;
          btn.classList.add('is-copied');
          if (resetTimer) clearTimeout(resetTimer);
          resetTimer = setTimeout(function () {
            btn.textContent = defaultLabel;
            btn.classList.remove('is-copied');
          }, 2400);
        };

        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(done).catch(function () {
            fallback();
          });
        } else {
          fallback();
        }

        function fallback() {
          var ta = document.createElement('textarea');
          ta.value = text;
          ta.setAttribute('readonly', '');
          ta.style.position = 'absolute';
          ta.style.left = '-9999px';
          document.body.appendChild(ta);
          ta.select();
          try { document.execCommand('copy'); done(); } catch (e) { /* noop */ }
          document.body.removeChild(ta);
        }
      });
    })();
  </script>

  <!-- ════════════════════════════════════════════════════════════
       Structured data : NewsArticle
       ════════════════════════════════════════════════════════════ -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    "headline": "StartSuite Launches Brand HQ, a Curation Layer for Lean Teams Shipping at Scale",
    "datePublished": "2026-05-05",
    "author": [
      { "@type": "Organization", "name": "StartSuite" }
    ],
    "publisher": {
      "@type": "Organization",
      "name": "StartSuite",
      "logo": {
        "@type": "ImageObject",
        "url": "https://start-suite.com/images/logo-full-dark.png"
      }
    }
  })} />
</BaseLayout>

<style>
  /* ─── HERO ─────────────────────────────────────────────────── */
  .pa-hero{
    padding:140px 48px 60px;
    position:relative;overflow:hidden;
  }
  .pa-hero::before{
    content:'';position:absolute;top:-180px;left:25%;
    width:900px;height:600px;pointer-events:none;
    background:radial-gradient(ellipse,rgba(139,109,181,0.08) 0%,transparent 60%);
  }
  .pa-hero-inner{
    max-width:880px;margin:0 auto;
    position:relative;z-index:1;
  }
  .pa-hero-meta-top{
    display:flex;align-items:center;justify-content:space-between;
    gap:16px;margin-bottom:32px;
  }
  .pa-back-top{
    font-family:var(--mono);
    font-size:11px;font-weight:700;letter-spacing:0.14em;
    text-transform:uppercase;color:var(--text-dim);
    text-decoration:none;
    transition:color var(--duration) var(--ease);
  }
  .pa-back-top:hover{color:var(--text)}
  #pa-copy-btn{
    cursor:pointer;
  }
  #pa-copy-btn.is-copied{
    background:linear-gradient(135deg,var(--purple-light) 0%,#D4BEE8 100%);
  }
  .pa-hero h1{
    font-size:clamp(32px,4.2vw,52px);
    background:linear-gradient(160deg,#fff 30%,var(--accent) 100%);
    -webkit-background-clip:text;-webkit-text-fill-color:transparent;
    background-clip:text;
    letter-spacing:-0.035em;line-height:1.08;
    margin-top:24px;margin-bottom:18px;
  }
  .pa-subtitle{
    font-family:var(--mono);
    font-size:12px;font-weight:600;letter-spacing:0.16em;
    text-transform:uppercase;color:var(--purple-light);
  }

  /* ─── BODY ─────────────────────────────────────────────────── */
  .pa-body{
    padding:64px 48px 80px;
  }
  .pa-body-inner{
    max-width:760px;margin:0 auto;
  }
  .pa-deck{
    font-size:18px;line-height:1.7;
    color:var(--text);
    font-weight:500;letter-spacing:-0.005em;
    padding-bottom:28px;margin-bottom:32px;
    border-bottom:1px solid var(--border);
  }
  .pa-body-inner p{
    font-size:16px;line-height:1.85;
    color:var(--text-muted);
    margin-bottom:22px;
  }
  .pa-body-inner p strong{color:var(--text);font-weight:600}
  .pa-quote{
    margin:36px 0;
    padding:28px 32px;
    background:rgba(139,109,181,0.06);
    border-left:3px solid var(--purple-light);
    border-radius:0 var(--radius-md) var(--radius-md) 0;
  }
  .pa-quote p{
    font-family:'Georgia','Times New Roman',serif;
    font-size:19px;line-height:1.55;
    color:var(--text);
    font-style:italic;font-weight:400;
    letter-spacing:-0.005em;
    margin-bottom:14px;
  }
  .pa-quote footer{
    font-family:var(--mono);
    font-size:11px;font-weight:600;letter-spacing:0.14em;
    text-transform:uppercase;color:var(--purple-light);
  }
  .pa-section-heading{
    font-size:20px;font-weight:800;
    letter-spacing:-0.02em;line-height:1.2;
    color:var(--text);
    margin-top:48px;margin-bottom:14px;
    padding-top:32px;
    border-top:1px solid var(--border);
  }
  .pa-contacts{
    display:grid;grid-template-columns:1fr 1fr;gap:32px;
    margin-top:8px;
  }
  .pa-contact-block p{margin-bottom:6px;font-size:15px}
  .pa-contact-label{
    font-family:var(--mono);
    font-size:10px;font-weight:700;letter-spacing:0.16em;
    text-transform:uppercase;color:var(--text-dim);
    margin-bottom:10px !important;
  }
  .pa-contact-name{
    color:var(--text) !important;font-weight:600;
  }
  .pa-contact-phone{
    font-family:var(--mono);font-size:14px;
    color:var(--text-muted);
  }
  .pa-contact-block a{
    color:var(--purple-light);text-decoration:none;
    border-bottom:1px solid rgba(196,169,224,0.3);
    transition:color var(--duration) var(--ease);
  }
  .pa-contact-block a:hover{color:var(--text)}

  /* ─── BACK ─────────────────────────────────────────────────── */
  .pa-back-section{
    padding:32px 48px 120px;
    border-top:1px solid var(--border);
  }
  .pa-back-inner{
    max-width:760px;margin:0 auto;
    text-align:center;
  }
  .pa-back-link{
    display:inline-block;
    font-family:var(--mono);
    font-size:11px;font-weight:700;letter-spacing:0.14em;
    text-transform:uppercase;color:var(--purple-light);
    text-decoration:none;
    padding:12px 22px;border-radius:100px;
    background:rgba(139,109,181,0.08);
    border:1px solid rgba(139,109,181,0.22);
    transition:all var(--duration) var(--ease);
  }
  .pa-back-link:hover{
    background:rgba(139,109,181,0.16);
    border-color:rgba(196,169,224,0.4);color:#fff;
    transform:translateY(-2px);
  }

  /* ─── MOBILE ───────────────────────────────────────────────── */
  @media (max-width: 900px){
    .pa-hero{padding:120px 24px 48px}
    .pa-hero-meta-top{flex-direction:column;align-items:flex-start;gap:12px}
    .pa-body{padding:48px 24px 64px}
    .pa-quote{padding:22px 24px;margin:28px 0}
    .pa-contacts{grid-template-columns:1fr;gap:24px}
    .pa-back-section{padding:28px 24px 96px}
  }

  @media (max-width: 480px){
    .pa-hero h1{font-size:clamp(26px,7vw,34px)}
    .pa-deck{font-size:16px}
    .pa-quote p{font-size:17px}
  }
</style>

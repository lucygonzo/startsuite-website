import DimLine from '@/components/DimLine.astro';

const PRESS_CONTACT_EMAIL = 'reagan@start-suite.com';
const FORTY_SIX_CONTACT_NAME = 'Kate Lynn';
const FORTY_SIX_CONTACT_PHONE = '817-851-8036';
const REAGAN_PHONE = '903-815-0560';
const RELEASE_DATE = 'May 5, 2026';
---

<BaseLayout
  title="StartSuite Launches Brand HQ · Press Release"
  description="StartSuite launches Brand HQ, a curation layer for lean teams shipping at scale. Tulsa and Nashville, May 5, 2026."
  ogTitle="StartSuite Launches Brand HQ"
  ogDescription="A new category for companies that have outgrown agency retainers but cannot yet afford a full-time CMO. Powered by 46 Capital."

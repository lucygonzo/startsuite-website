---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ChampionsKit from '@/components/ChampionsKit.astro';
import opData from '@/data/for-operators.yaml';

const {
  meta,
  referenceBrand,
  hero,
  empathy,
  pillars,
  beforeAfter,
  whyNow,
  roi,
  jobs,
  caseStudy,
  isnt,
  vcInHouse,
  crossLinks,
  faq,
  finalCta,
  championKit,
} = opData;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.items.map((item: any) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a },
  })),
};
---

<BaseLayout title={meta.title} description={meta.description}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>

  <!-- ─── HERO ─── -->
  <section class="op-hero">
    <div class="op-hero-glow" aria-hidden="true"></div>
    <div class="op-hero-inner">
      <div class="op-hero-text">
        <p class="op-eyebrow">{hero.eyebrow}</p>
        <h1>
          <span class="op-hero-lead">{hero.headline_lead}</span>
          <em>{hero.headline_emphasis}</em>
        </h1>
        <p class="op-hero-sub">{hero.subhead}</p>
        <div class="op-hero-ctas">
          <a class="btn btn-primary btn-lg" onclick={hero.cta_primary_action} style="cursor:pointer">{hero.cta_primary} →</a>
          <a class="btn btn-outline btn-lg" href={hero.cta_secondary_href}>{hero.cta_secondary} →</a>
        </div>
      </div>
      <div class="op-hero-visual">
        <!-- Slot 1: tool consolidation animation -->
        <div class="op-mock op-mock-consolidate" aria-hidden="true">
          <div class="op-mock-chrome"><span></span><span></span><span></span><em>{referenceBrand} · Brand HQ · Stack consolidation</em></div>
          <div class="op-mock-body">
            <div class="op-consolidate-stage">
              <div class="op-consolidate-tools">
                <span class="op-tool" style="--d:0">PDF</span>
                <span class="op-tool" style="--d:1">Notion</span>
                <span class="op-tool" style="--d:2">Figma</span>
                <span class="op-tool" style="--d:3">Frontify</span>
                <span class="op-tool" style="--d:4">CRM</span>
                <span class="op-tool" style="--d:5">Drive</span>
              </div>
              <div class="op-consolidate-arrow">↓</div>
              <div class="op-consolidate-target">
                <div class="op-consolidate-target-cap">
                  <span class="op-pulse"></span>
                  Brand HQ · structured
                </div>
                <div class="op-consolidate-target-grid">
                  <div>Brand</div>
                  <div>Market</div>
                  <div>Strategy</div>
                  <div>Intel</div>
                  <div>Ops</div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <p class="op-hero-caption">{hero.visual_caption}</p>
      </div>
    </div>
  </section>

  <!-- ─── EMPATHY: 3 rhythmic statements ─── -->
  <section class="op-empathy section-alt">
    <div class="op-empathy-inner">
      <header class="op-empathy-header">
        <h2>{empathy.header}</h2>
      </header>
      <ol class="op-empathy-lines">
        {empathy.lines.map((line: string, i: number) => (
          <li class="scroll-reveal" style={`--i:${i}`}>
            <span class="op-empathy-num">{String(i + 1).padStart(2, '0')}</span>
            <p>{line}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ─── PILLARS: 4 cards in 2x2 ─── -->
  <section class="op-pillars">
    <div class="op-pillars-inner">
      <header class="op-pillars-header scroll-reveal">
        <h2>{pillars.header}</h2>
        <p class="op-pillars-sub">{pillars.subhead}</p>
      </header>
      <div class="op-pillars-grid">
        {pillars.cards.map((card: any, i: number) => (
          <article class={`op-pillar op-pillar-${card.icon} scroll-reveal`} style={`--i:${i}`}>
            <div class="op-pillar-icon" aria-hidden="true">
              {card.icon === 'strategy' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="3"/>
                  <path d="M12 2v3M12 19v3M2 12h3M19 12h3"/>
                </svg>
              )}
              {card.icon === 'work' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 8h18M3 16h18M8 3v18M16 3v18"/>
                </svg>
              )}
              {card.icon === 'signals' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 12h4l3-7 4 14 3-7h4"/>
                </svg>
              )}
              {card.icon === 'context' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="6" cy="6" r="2"/>
                  <circle cx="18" cy="6" r="2"/>
                  <circle cx="6" cy="18" r="2"/>
                  <circle cx="18" cy="18" r="2"/>
                  <path d="M8 6h8M8 18h8M6 8v8M18 8v8" stroke-dasharray="2 3"/>
                </svg>
              )}
            </div>
            <h3>{card.title}</h3>
            <p>{card.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── BEFORE / AFTER ─── -->
  <section class="op-ba section-alt">
    <div class="op-ba-inner">
      <header class="op-ba-header scroll-reveal">
        <p class="op-section-eyebrow">Before / After</p>
        <h2>{beforeAfter.header}</h2>
      </header>
      <div class="op-ba-rows">
        <div class="op-ba-cols-header" aria-hidden="true">
          <span>Now</span>
          <span></span>
          <span>With StartSuite</span>
        </div>
        {beforeAfter.rows.map((row: any, i: number) => (
          <div class="op-ba-row scroll-reveal" style={`--i:${i}`}>
            <div class="op-ba-now">{row.now}</div>
            <div class="op-ba-arrow" aria-hidden="true">
              <svg viewBox="0 0 100 12" preserveAspectRatio="none">
                <line x1="0" y1="6" x2="92" y2="6" />
                <polyline points="84,2 99,6 84,10"/>
              </svg>
            </div>
            <div class="op-ba-after">{row.after}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── WHY NOW: 3 columns ─── -->
  <section class="op-why">
    <div class="op-why-inner">
      <header class="op-why-header scroll-reveal">
        <h2>{whyNow.header}</h2>
        <p class="op-why-body">{whyNow.body}</p>
      </header>
      <div class="op-why-grid">
        {whyNow.columns.map((col: any, i: number) => (
          <article class="op-why-col scroll-reveal" style={`--i:${i}`}>
            <span class="op-why-num">{String(i + 1).padStart(2, '0')}</span>
            <h3>{col.title}</h3>
            <p>{col.copy}</p>
            <div class="op-why-visual">
              {col.visual === 'library' && (
                <div class="op-mock op-mock-library">
                  <div class="op-mock-chrome"><span></span><span></span><span></span><em>{referenceBrand} · Library</em></div>
                  <div class="op-mock-body">
                    <div class="op-mock-cap">
                      <span class="op-pulse"></span>
                      One source · all teams
                    </div>
                    <div class="op-library-grid">
                      <div><strong>Logo</strong><em>SVG · PNG</em></div>
                      <div><strong>Color</strong><em>v2.1</em></div>
                      <div><strong>Type</strong><em>System</em></div>
                      <div><strong>Voice</strong><em>5 rules</em></div>
                      <div><strong>Photo</strong><em>Direction</em></div>
                      <div><strong>Motion</strong><em>Tokens</em></div>
                    </div>
                    <div class="op-library-meta">
                      <span>3 agencies briefed this month</span>
                    </div>
                  </div>
                </div>
              )}
              {col.visual === 'performance' && (
                <div class="op-mock op-mock-performance">
                  <div class="op-mock-chrome"><span></span><span></span><span></span><em>{referenceBrand} · Performance</em></div>
                  <div class="op-mock-body">
                    <div class="op-mock-cap">
                      Brand pillars · revenue tied
                    </div>
                    <div class="op-perf-pillars">
                      <div>
                        <strong>Trust</strong>
                        <div class="op-perf-bar"><span style="width:78%"></span></div>
                        <em>+12% Q3</em>
                      </div>
                      <div>
                        <strong>Speed</strong>
                        <div class="op-perf-bar"><span style="width:64%"></span></div>
                        <em>+6% Q3</em>
                      </div>
                      <div>
                        <strong>Scale</strong>
                        <div class="op-perf-bar"><span style="width:84%"></span></div>
                        <em>+18% Q3</em>
                      </div>
                    </div>
                    <div class="op-perf-revenue">
                      <span>Campaign-to-revenue</span>
                      <strong>2.4x baseline</strong>
                    </div>
                  </div>
                </div>
              )}
              {col.visual === 'onboarding' && (
                <div class="op-mock op-mock-onboarding">
                  <div class="op-mock-chrome"><span></span><span></span><span></span><em>{referenceBrand} · Onboarding</em></div>
                  <div class="op-mock-body">
                    <div class="op-mock-cap">New agency · day one</div>
                    <ol class="op-onboarding-list">
                      <li><span>01</span><div><strong>Positioning</strong><em>Canonical</em></div></li>
                      <li><span>02</span><div><strong>Voice</strong><em>5 rules</em></div></li>
                      <li><span>03</span><div><strong>Recent decisions</strong><em>Last 30 days</em></div></li>
                      <li><span>04</span><div><strong>Active workstreams</strong><em>4 in flight</em></div></li>
                    </ol>
                  </div>
                </div>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── ROI ─── -->
  <section class="op-roi">
    <div class="op-roi-inner">
      <header class="op-roi-header scroll-reveal">
        <h2>{roi.header}</h2>
      </header>
      <div class="op-roi-grid">
        {roi.blocks.map((b: any, i: number) => (
          <article class="op-roi-block scroll-reveal" style={`--i:${i}`}>
            <div class="op-roi-claim">{b.claim}</div>
            <h3>{b.title}</h3>
            <p>{b.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── JOBS: 5 paired cards ─── -->
  <section class="op-jobs">
    <div class="op-jobs-inner">
      <header class="op-jobs-header scroll-reveal">
        <h2>{jobs.header}</h2>
      </header>
      <div class="op-jobs-grid">
        {jobs.cards.map((card: any, i: number) => (
          <article class="op-job scroll-reveal" style={`--i:${i}`}>
            <div class="op-job-visual">
              {card.visual === 'refresh' && (
                <div class="op-mock op-mock-refresh">
                  <div class="op-mock-chrome"><span></span><span></span><span></span><em>{referenceBrand} · Refresh workspace</em></div>
                  <div class="op-mock-body">
                    <div class="op-mock-cap">Brand refresh · in flight</div>
                    <div class="op-refresh-streams">
                      <div class="op-refresh-row">
                        <span class="op-refresh-status active"></span>
                        <strong>Voice principles update</strong>
                        <em>Active</em>
                      </div>
                      <div class="op-refresh-row">
                        <span class="op-refresh-status active"></span>
                        <strong>Identity v3 rollout</strong>
                        <em>Active</em>
                      </div>
                      <div class="op-refresh-row">
                        <span class="op-refresh-status review"></span>
                        <strong>Audience refresh</strong>
                        <em>In review</em>
                      </div>
                      <div class="op-refresh-row">
                        <span class="op-refresh-status done"></span>
                        <strong>Positioning lock</strong>
                        <em>Decided</em>
                      </div>
                    </div>
                    <div class="op-refresh-note">Decisions logged · team kept moving</div>
                  </div>
                </div>
              )}
              {card.visual === 'share' && (
                <div class="op-mock op-mock-share">
                  <div class="op-mock-chrome"><span></span><span></span><span></span><em>{referenceBrand} · Operating Standards</em></div>
                  <div class="op-mock-body">
                    <div class="op-mock-cap">Ready to brief</div>
                    <div class="op-share-tile">
                      <div class="op-share-row">
                        <span>Agency access</span>
                        <em>Read-only · 30 days</em>
                      </div>
                      <div class="op-share-link">
                        <code>brand.atlasco.com/standards</code>
                        <button>Copy</button>
                      </div>
                    </div>
                    <div class="op-share-meta">
                      <span>One call, not three</span>
                    </div>
                  </div>
                </div>
              )}
              {card.visual === 'boardroom' && (
                <div class="op-mock op-mock-boardroom">
                  <div class="op-mock-chrome"><span></span><span></span><span></span><em>{referenceBrand} · Board readout</em></div>
                  <div class="op-mock-body">
                    <div class="op-mock-cap">Q3 brand impact</div>
                    <div class="op-board-stats">
                      <div>
                        <strong>+8%</strong>
                        <em>Category share</em>
                      </div>
                      <div>
                        <strong>+22%</strong>
                        <em>Audience growth</em>
                      </div>
                      <div>
                        <strong>+0.6</strong>
                        <em>Sentiment trajectory</em>
                      </div>
                    </div>
                    <div class="op-board-rev">
                      <span>Campaign-to-revenue</span>
                      <strong>2.4x baseline</strong>
                    </div>
                  </div>
                </div>
              )}
              {card.visual === 'competitive' && (
                <div class="op-mock op-mock-competitive">
                  <div class="op-mock-chrome"><span></span><span></span><span></span><em>{referenceBrand} · Category signals</em></div>
                  <div class="op-mock-body">
                    <div class="op-mock-cap">
                      <span class="op-pulse"></span>
                      Filtered by your strategy
                    </div>
                    <div class="op-comp-list">
                      <div class="op-comp-row">
                        <span class="op-comp-marker high"></span>
                        <div><strong>Competitor X · Series B</strong><em>Funding · high</em></div>
                      </div>
                      <div class="op-comp-row">
                        <span class="op-comp-marker mid"></span>
                        <div><strong>Category report dropped</strong><em>Industry · medium</em></div>
                      </div>
                      <div class="op-comp-row">
                        <span class="op-comp-marker high"></span>
                        <div><strong>Audience shift in survey</strong><em>Audience · high</em></div>
                      </div>
                      <div class="op-comp-row">
                        <span class="op-comp-marker low"></span>
                        <div><strong>Adjacent tool launched</strong><em>Adjacent · low</em></div>
                      </div>
                    </div>
                  </div>
                </div>
              )}
              {card.visual === 'handoff' && (
                <div class="op-mock op-mock-handoff">
                  <div class="op-mock-chrome"><span></span><span></span><span></span><em>{referenceBrand} · Handoff log</em></div>
                  <div class="op-mock-body">
                    <div class="op-mock-cap">Brand stays · person changes</div>
                    <div class="op-handoff-list">
                      <div>
                        <strong>Voice update for press</strong>
                        <em>Approved by CMO · Mar 14</em>
                      </div>
                      <div>
                        <strong>Audience refresh</strong>
                        <em>Owned by VP Brand · in flight</em>
                      </div>
                      <div>
                        <strong>Repositioning narrative</strong>
                        <em>Canonical · last reviewed Jan 9</em>
                      </div>
                    </div>
                    <div class="op-handoff-foot">
                      <span>Next person walks in ahead</span>
                    </div>
                  </div>
                </div>
              )}
            </div>
            <div class="op-job-text">
              <span class="op-job-num">{String(i + 1).padStart(2, '0')}</span>
              <h3>{card.title}</h3>
              <p>{card.copy}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CASE STUDY ─── -->
  <section class="op-case section-alt">
    <div class="op-case-inner">
      <header class="op-case-header scroll-reveal">
        <h2>{caseStudy.header}</h2>
      </header>
      <div class="op-case-body scroll-reveal">
        <p class="op-case-narrative">{caseStudy.body}</p>
        <figure class="op-case-quote">
          <span class="op-case-glyph" aria-hidden="true">&ldquo;</span>
          <blockquote>{caseStudy.quote}</blockquote>
          <figcaption>
            <span class="op-case-rule" aria-hidden="true"></span>
            {caseStudy.attribution}
          </figcaption>
        </figure>
      </div>
      <div class="op-case-visual scroll-reveal" aria-hidden="true">
        <div class="op-mock op-mock-overview">
          <div class="op-mock-chrome"><span></span><span></span><span></span><em>{referenceBrand} · Brand HQ · Overview</em></div>
          <div class="op-mock-body op-mock-overview-body">
            <aside class="op-mock-overview-nav">
              <span class="is-active">Brand</span>
              <span>Market</span>
              <span>Strategy</span>
              <span>Intelligence</span>
              <span>Operations</span>
            </aside>
            <main class="op-mock-overview-main">
              <div class="op-mock-overview-cap">Brand · Positioning</div>
              <h6>The brand operating system for teams running real complexity.</h6>
              <div class="op-mock-overview-bars">
                <div style="width:82%"></div>
                <div style="width:64%"></div>
                <div style="width:74%"></div>
              </div>
              <div class="op-mock-overview-grid">
                <div><strong>Audience</strong><em>3 personas</em></div>
                <div><strong>Voice</strong><em>5 principles</em></div>
                <div><strong>Identity</strong><em>System v2.1</em></div>
                <div><strong>Standards</strong><em>14 rules</em></div>
              </div>
            </main>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── ISN'T / IS ─── -->
  <section class="op-isnt">
    <div class="op-isnt-inner">
      <header class="op-isnt-header scroll-reveal">
        <h2>{isnt.header}</h2>
      </header>
      <div class="op-isnt-grid">
        <div class="op-isnt-col scroll-reveal">
          <p class="op-isnt-col-label">What this isn't</p>
          <ul class="op-isnt-list op-isnt-list-dont">
            {isnt.dont.map((item: string) => <li>{item}</li>)}
          </ul>
        </div>
        <div class="op-isnt-col scroll-reveal">
          <p class="op-isnt-col-label">{isnt.do.title}</p>
          <ul class="op-isnt-list op-isnt-list-do">
            {isnt.do.items.map((item: string) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── VC IN HOUSE ─── -->
  <section class="op-vc">
    <div class="op-vc-inner scroll-reveal">
      <p class="op-section-eyebrow">From the team</p>
      <h2>{vcInHouse.header}</h2>
      <p>{vcInHouse.body}</p>
      {vcInHouse.cta && (
        <a class="op-vc-link" href={vcInHouse.href}>{vcInHouse.cta} →</a>
      )}
    </div>
  </section>

  <!-- ─── CROSS LINKS ─── -->
  <section class="op-cross section-alt">
    <div class="op-cross-inner">
      <header class="op-cross-header scroll-reveal">
        <h2>{crossLinks.header}</h2>
      </header>
      <div class="op-cross-grid">
        {crossLinks.cards.map((card: any) => (
          <article class="op-cross-card scroll-reveal">
            <h3>{card.heading}</h3>
            <p>{card.copy}</p>
            <a class="op-cross-cta" href={card.href}>{card.cta} →</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── FAQ ─── -->
  <section class="op-faq">
    <div class="op-faq-inner">
      <header class="op-faq-header scroll-reveal">
        <p class="op-section-eyebrow">{faq.eyebrow}</p>
        <h2>{faq.header}</h2>
      </header>
      <div class="op-faq-list">
        {faq.items.map((item: any, i: number) => (
          <details class="op-faq-item scroll-reveal" style={`--i:${i}`} open={i === 0}>
            <summary>
              <span class="op-faq-q">{item.q}</span>
              <span class="op-faq-icon" aria-hidden="true"></span>
            </summary>
            <p class="op-faq-a">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── FINAL CTA ─── -->
  <section class="op-final">
    <div class="op-final-glow" aria-hidden="true"></div>
    <div class="op-final-inner">
      <h2 class="scroll-reveal">{finalCta.header}</h2>
      <p class="scroll-reveal">{finalCta.body}</p>
      <div class="op-final-ctas scroll-reveal">
        <a class="btn btn-primary btn-lg" onclick={finalCta.cta_primary_action} style="cursor:pointer">{finalCta.cta_primary} →</a>
        <a class="btn btn-ghost btn-lg" onclick={finalCta.cta_secondary_action} style="cursor:pointer">{finalCta.cta_secondary} →</a>
      </div>
    </div>
  </section>

  <ChampionsKit
    closedLabel={championKit.closedLabel}
    microcopy={championKit.microcopy}
    items={championKit.items}
    href={championKit.href}
  />

</BaseLayout>

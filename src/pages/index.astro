---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroSection from '@/components/home/HeroSection.astro';
import PricingPill from '@/components/home/PricingPill.astro';
import MarqueeStrip from '@/components/MarqueeStrip.astro';
import BrandHqExplainer from '@/components/home/BrandHqExplainer.astro';
import DimLine from '@/components/DimLine.astro';
import HowItWorks from '@/components/home/HowItWorks.astro';
import WhyStartSuite from '@/components/home/WhyStartSuite.astro';
import PartnerTeaser from '@/components/home/PartnerTeaser.astro';
import FinalCta from '@/components/home/FinalCta.astro';
import LimitedEngagements from '@/components/LimitedEngagements.astro';

import homeData from '@/data/home.yaml';
---

<BaseLayout
  title="StartSuite · Brand Operating System for Founders and Teams"
  description="StartSuite is the brand operating system for founders and growing teams. Brand HQ centralizes identity, competitive intelligence, audience, and creative in one structured system. Foundations $3K/month. Backed by 46 Capital."
>
  <HeroSection />
  <PricingPill />
  <MarqueeStrip items={homeData.marquee.items} />
  <BrandHqExplainer />
  <DimLine label="How it works" />
  <HowItWorks />
  <DimLine label="Why us" />
  <WhyStartSuite />
  <PartnerTeaser />
  <FinalCta />
  <LimitedEngagements />
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PartnersHero from '@/components/partners/PartnersHero.astro';
import TheGap from '@/components/partners/TheGap.astro';
import DimLine from '@/components/DimLine.astro';
import HowWeIntegrate from '@/components/partners/HowWeIntegrate.astro';
import PartnershipModels from '@/components/partners/PartnershipModels.astro';
import PilotCta from '@/components/partners/PilotCta.astro';
import WhoWeWorkWith from '@/components/partners/WhoWeWorkWith.astro';

import partnersData from '@/data/partners.yaml';
---

<BaseLayout title="Partners — StartSuite">
  <PartnersHero />
  <DimLine label={partnersData.the_gap.dim_line_label} />
  <TheGap />
  <HowWeIntegrate />
  <DimLine label={partnersData.partnership_models.dim_line_label} />
  <PartnershipModels />
  <PilotCta />
  <DimLine label={partnersData.who_we_work_with.dim_line_label} />
  <WhoWeWorkWith />
</BaseLayout>

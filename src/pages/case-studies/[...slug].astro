---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const studies = await getCollection('case-studies');
  return studies.map(study => ({
    params: { slug: study.slug },
    props: { study },
  }));
}

const { study } = Astro.props;
const { Content } = await study.render();
---

<BaseLayout title={`${study.data.title} · StartSuite`}>

<article style="padding:180px 40px 80px;max-width:800px;margin:0 auto">
  <a href="/case-studies" style="display:inline-flex;align-items:center;gap:6px;color:var(--text-muted);text-decoration:none;font-size:13px;font-weight:500;margin-bottom:40px;transition:color 0.3s var(--ease)">
    &larr; All Case Studies
  </a>

  <div style="font-size:10px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:var(--purple-light);margin-bottom:16px;font-family:var(--mono)">{study.data.industry} · {study.data.client}</div>

  <h1 style="font-size:clamp(32px,4vw,48px);margin-bottom:20px;line-height:1.1">{study.data.title}</h1>
  <p style="color:var(--text-muted);font-size:17px;line-height:1.8;margin-bottom:48px">{study.data.summary}</p>

  {study.data.stats && (
    <div style="display:flex;gap:32px;margin-bottom:48px;padding:28px 32px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg)">
      {study.data.stats.map(stat => (
        <div>
          <div style="font-size:24px;font-weight:800;color:var(--purple-light)">{stat.value}</div>
          <div style="font-size:12px;color:var(--text-dim);text-transform:uppercase;letter-spacing:0.08em;margin-top:4px">{stat.label}</div>
        </div>
      ))}
    </div>
  )}

  <div class="prose" style="color:var(--text-muted);font-size:16px;line-height:1.85">
    <Content />
  </div>

  {study.data.testimonial && (
    <blockquote style="margin:56px 0;padding:32px 36px;background:var(--surface);border-left:3px solid var(--purple);border-radius:0 var(--radius-md) var(--radius-md) 0">
      <p style="font-size:17px;font-style:italic;color:var(--text);line-height:1.7;margin-bottom:16px">"{study.data.testimonial.quote}"</p>
      <div style="font-size:13px;font-weight:600;color:var(--text)">{study.data.testimonial.name}</div>
      <div style="font-size:12px;color:var(--text-muted)">{study.data.testimonial.role}</div>
    </blockquote>
  )}
</article>

</BaseLayout>

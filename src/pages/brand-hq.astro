---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ClientBand from '@/components/home/ClientBand.astro';
import bhqData from '@/data/brand-hq.yaml';

const {
  meta,
  hero,
  showcase,
  definition,
  yoursSpecifically,
  flow,
  inputs,
  northStar,
  publicOutputs,
  stack,
  whosUsing,
  quote,
  faq,
  finalCta,
} = bhqData;

// Pre-compute petal positions for the radial north star
const NS_RADIUS = 110;
const petals = northStar.sections.map((s: any, i: number) => {
  const angle = (-90 + i * 72) * (Math.PI / 180);
  return {
    ...s,
    key: s.title.toLowerCase(),
    x: Math.cos(angle) * NS_RADIUS,
    y: Math.sin(angle) * NS_RADIUS,
    labelX: Math.cos(angle) * (NS_RADIUS + 26),
    labelY: Math.sin(angle) * (NS_RADIUS + 26),
    angle: i * 72,
  };
});

// Build JSON-LD for SEO/GEO
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.items.map((item: any) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a },
  })),
};

const productSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Brand HQ",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web",
  "description": meta.description,
  "url": "https://start-suite.com/brand-hq",
  "creator": {
    "@type": "Organization",
    "name": "StartSuite",
    "url": "https://start-suite.com",
  },
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "url": "https://start-suite.com/pricing",
  },
};
---

<BaseLayout title={meta.title} description={meta.description} ogTitle={meta.ogTitle} ogDescription={meta.ogDescription}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(productSchema)}></script>

  <!-- ─── HERO ─── -->
  <section class="bhq-hero">
    <div class="bhq-hero-glow" aria-hidden="true"></div>
    <div class="bhq-hero-inner">
      <p class="bhq-eyebrow">{hero.eyebrow}</p>
      <h1>
        <span class="bhq-hero-lead">{hero.headline_lead}</span>
        <span class="bhq-hero-line"><em>{hero.headline_emphasis}</em> {hero.headline_tail}</span>
      </h1>
      <p class="bhq-hero-tagline">{hero.tagline}</p>
      <p class="bhq-hero-sub">{hero.subhead}</p>
      <div class="bhq-hero-ctas">
        <a class="btn btn-primary btn-lg" onclick={hero.cta_primary_action} style="cursor:pointer">{hero.cta_primary} →</a>
        <a class="btn btn-outline btn-lg" href={hero.cta_secondary_target}>{hero.cta_secondary} ↓</a>
      </div>
    </div>
  </section>

  <!-- ─── SHOWCASE (3 mock screenshots) ─── -->
  <section class="bhq-showcase" id="showcase">
    <div class="bhq-showcase-inner">
      <p class="bhq-section-eyebrow">{showcase.eyebrow}</p>
      <div class="bhq-showcase-grid">
        {showcase.shots.map((s) => (
          <figure class="bhq-shot scroll-reveal">
            <div class={`bhq-shot-mock bhq-shot-${s.kind}`} aria-hidden="true">
              <div class="bhq-shot-chrome"><span></span><span></span><span></span></div>
              <div class="bhq-shot-body">
                {s.kind === 'industry' && (
                  <>
                    <div class="bhq-mock-cap">
                      <span class="bhq-mock-pulse"></span>
                      IIJA funding window · open
                    </div>
                    <h6>Industry Landscape</h6>
                    <div class="bhq-mock-states">
                      <div><span>MN</span><em>4 active</em></div>
                      <div><span>WI</span><em>2 active</em></div>
                      <div><span>IA</span><em>1 active</em></div>
                      <div><span>ND</span><em>3 active</em></div>
                      <div><span>SD</span><em>2 active</em></div>
                      <div><span>NE</span><em>1 active</em></div>
                    </div>
                    <div class="bhq-mock-countdown">
                      <span class="bhq-mock-countdown-num">91</span>
                      <span class="bhq-mock-countdown-lbl">days to centennial</span>
                    </div>
                  </>
                )}
                {s.kind === 'listening' && (
                  <>
                    <div class="bhq-mock-cap">
                      <span class="bhq-mock-pulse bhq-mock-pulse-green"></span>
                      14 mentions · 2 alerts
                    </div>
                    <h6>Listening Feed</h6>
                    <div class="bhq-mock-feed">
                      <div class="bhq-mock-mention">
                        <div class="bhq-mock-mention-meta"><span>Forbes</span><em class="pos">positive</em></div>
                        <p>"...notable executive moves at the firm signal a new strategic posture..."</p>
                      </div>
                      <div class="bhq-mock-mention">
                        <div class="bhq-mock-mention-meta"><span>TechCrunch</span><em class="neu">neutral</em></div>
                        <p>"...new partnership announcement reframes the category positioning..."</p>
                      </div>
                      <div class="bhq-mock-mention">
                        <div class="bhq-mock-mention-meta"><span>LinkedIn</span><em class="pos">positive</em></div>
                        <p>"...team is building something different from the usual playbook..."</p>
                      </div>
                    </div>
                  </>
                )}
                {s.kind === 'logo' && (
                  <>
                    <div class="bhq-mock-cap">
                      <span class="bhq-mock-pulse"></span>
                      Latest update · 2d ago
                    </div>
                    <h6>Logo System</h6>
                    <div class="bhq-mock-logo">
                      <div class="bhq-mock-logo-art" aria-hidden="true">
                        <svg viewBox="0 0 80 80" fill="none">
                          <circle cx="40" cy="40" r="34" stroke="currentColor" stroke-width="2"/>
                          <path d="M28 40h24M40 28v24" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                      </div>
                      <div class="bhq-mock-logo-formats">
                        <span>SVG</span>
                        <span>PNG</span>
                        <span>WEBP</span>
                        <span>EPS</span>
                      </div>
                      <div class="bhq-mock-logo-variants">
                        <div class="dark"></div>
                        <div class="light"></div>
                        <div class="mark"></div>
                      </div>
                    </div>
                  </>
                )}
              </div>
            </div>
            <figcaption>{s.caption}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── DEFINITION (one-line for GEO/LLM citation) ─── -->
  <section class="bhq-define">
    <div class="bhq-define-inner">
      <p class="bhq-define-eyebrow">What is Brand HQ?</p>
      <p class="bhq-define-text">{definition.text}</p>
    </div>
  </section>

  <!-- ─── YOURS, SPECIFICALLY (the wedge) ─── -->
  <section class="bhq-wedge section-alt">
    <div class="bhq-wedge-inner">
      <header class="bhq-wedge-header scroll-reveal">
        <p class="bhq-section-eyebrow">{yoursSpecifically.eyebrow}</p>
        <h2>{yoursSpecifically.header}</h2>
        <p class="bhq-wedge-body">{yoursSpecifically.body}</p>
        <p class="bhq-wedge-cap">{yoursSpecifically.examplesHeader}</p>
      </header>
      <ol class="bhq-wedge-examples">
        {yoursSpecifically.examples.map((ex, i) => (
          <li class="bhq-wedge-example scroll-reveal" style={`--i:${i}`}>
            <div class="bhq-wedge-meta">
              <span class="bhq-wedge-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="bhq-wedge-label">{ex.label}</span>
            </div>
            <p class="bhq-wedge-strategy">{ex.strategy}</p>
            <p class="bhq-wedge-arrow" aria-hidden="true">Brand HQ surfaces ↓</p>
            <ul class="bhq-wedge-surfaces">
              {ex.surfaces.map((s) => <li>{s}</li>)}
            </ul>
          </li>
        ))}
      </ol>
      <p class="bhq-wedge-closing scroll-reveal">{yoursSpecifically.closing}</p>
    </div>
  </section>

  <!-- ─── FLOW: Inputs → Radial North Star → Outputs (one connected story) ─── -->
  <section class="bhq-flow" data-bhq-flow>
    <div class="bhq-flow-header scroll-reveal">
      <p class="bhq-section-eyebrow">{flow.eyebrow}</p>
      <h2>{flow.header}</h2>
      <p class="bhq-flow-body">{flow.body}</p>
    </div>

    <div class="bhq-flow-grid">

      <div class="bhq-flow-band bhq-flow-band-inputs">
        <p class="bhq-flow-band-label" aria-hidden="true">Inputs</p>
        <ol class="bhq-flow-inputs" aria-label="Inputs to Brand HQ">
          {inputs.groups.map((g: any, i: number) => (
            <li class="bhq-flow-input" data-flow-input={i}>
              <span class="bhq-flow-input-dot" aria-hidden="true"></span>
              <div>
                <strong>{g.title}</strong>
                <span>{g.detail}</span>
              </div>
            </li>
          ))}
        </ol>
      </div>

      <div class="bhq-flow-band bhq-flow-band-core">
        <p class="bhq-flow-band-label" aria-hidden="true">North Star</p>
        <svg class="bhq-star" viewBox="-180 -160 360 320" aria-label="Brand HQ north star with five sections">
          <circle cx="0" cy="0" r="125" class="bhq-star-orbit bhq-star-orbit-outer" />
          <circle cx="0" cy="0" r="110" class="bhq-star-orbit" />
          <polygon points={petals.map((p: any) => `${p.x.toFixed(2)},${p.y.toFixed(2)}`).join(' ')} class="bhq-star-pentagon" />
          {petals.map((p: any) => (
            <line x1="0" y1="0" x2={p.x.toFixed(2)} y2={p.y.toFixed(2)} class="bhq-star-spoke" data-petal-spoke={p.key} />
          ))}
          <g class="bhq-star-center">
            <circle cx="0" cy="0" r="22" class="bhq-star-glow" />
            <circle cx="0" cy="0" r="6" class="bhq-star-core" />
            <line x1="-14" y1="0" x2="14" y2="0" />
            <line x1="0" y1="-14" x2="0" y2="14" />
            <line x1="-10" y1="-10" x2="10" y2="10" />
            <line x1="-10" y1="10" x2="10" y2="-10" />
          </g>
          {petals.map((p: any, i: number) => (
            <g
              class={`bhq-petal ${i === 0 ? 'is-active' : ''}`}
              data-petal={p.key}
              tabindex="0"
              role="button"
              aria-label={`Show ${p.title} features`}
            >
              <circle cx={p.x.toFixed(2)} cy={p.y.toFixed(2)} r="14" class="bhq-petal-glow" />
              <circle cx={p.x.toFixed(2)} cy={p.y.toFixed(2)} r="7" class="bhq-petal-dot" />
              <text
                x={p.labelX.toFixed(2)}
                y={p.labelY.toFixed(2)}
                text-anchor="middle"
                dominant-baseline="middle"
                class="bhq-petal-label"
              >{p.title}</text>
            </g>
          ))}
        </svg>

        <div class="bhq-flow-features" data-bhq-features>
          {petals.map((p: any, i: number) => (
            <div
              class={`bhq-flow-feature ${i === 0 ? 'is-active' : ''}`}
              data-feature={p.key}
              aria-hidden={i === 0 ? 'false' : 'true'}
            >
              <p class="bhq-flow-feature-eyebrow">{p.title}</p>
              <p class="bhq-flow-feature-lede">{p.lede}</p>
              {p.features && (
                <ul class="bhq-flow-feature-list">
                  {p.features.map((f: string) => <li>{f}</li>)}
                </ul>
              )}
              {p.tiers && (
                <div class="bhq-flow-feature-tiers">
                  <p class="bhq-flow-feature-tiers-label">Knowledge sorts into:</p>
                  {p.tiers.map((t: any) => (
                    <div class={`bhq-tier-mini bhq-tier-mini-${t.level.toLowerCase()}`}>
                      <span class="bhq-tier-mini-rail" aria-hidden="true"></span>
                      <div class="bhq-tier-mini-text">
                        <strong>{t.level}</strong>
                        <span>{t.copy}</span>
                      </div>
                    </div>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      </div>

      <div class="bhq-flow-band bhq-flow-band-outputs">
        <p class="bhq-flow-band-label" aria-hidden="true">Outputs</p>
        <ul class="bhq-flow-outputs" aria-label="Outputs from Brand HQ">
          {publicOutputs.outputs.map((o: any, i: number) => (
            <li class={`bhq-flow-output bhq-output-${o.kind}`} data-flow-output={i}>
              <span class="bhq-flow-output-dot" aria-hidden="true"></span>
              <div>
                <strong>{o.label}</strong>
                <span>{o.detail}</span>
              </div>
              <em class="bhq-flow-output-kind">{o.kind === 'public' ? 'Public' : o.kind === 'agent' ? 'Agent' : 'Internal'}</em>
            </li>
          ))}
        </ul>
      </div>

      <svg class="bhq-flow-lines" aria-hidden="true" data-bhq-lines></svg>

    </div>
  </section>

  <script is:inline>
    (function () {
      const root = document.querySelector('[data-bhq-flow]');
      if (!root) return;
      const linesSvg = root.querySelector('[data-bhq-lines]');
      const featurePanel = root.querySelector('[data-bhq-features]');
      const inputNodes = root.querySelectorAll('[data-flow-input]');
      const outputNodes = root.querySelectorAll('[data-flow-output]');
      const star = root.querySelector('.bhq-star');
      const petals = root.querySelectorAll('.bhq-petal');
      const spokes = root.querySelectorAll('[data-petal-spoke]');
      const grid = root.querySelector('.bhq-flow-grid');

      const reduceMotion = window.matchMedia &&
        window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      function rebuildLines() {
        if (!linesSvg || !grid || !star) return null;
        const gridRect = grid.getBoundingClientRect();
        const starRect = star.getBoundingClientRect();
        // Star receiving point: top-center (slight inset so it visually meets the orbit ring)
        const starInX = (starRect.left + starRect.width / 2) - gridRect.left;
        const starInY = (starRect.top + starRect.height * 0.18) - gridRect.top;
        // Output emerging point: bottom-center of feature panel (or star if panel missing)
        const sourceRect = featurePanel ? featurePanel.getBoundingClientRect() : starRect;
        const starOutX = (sourceRect.left + sourceRect.width / 2) - gridRect.left;
        const starOutY = sourceRect.bottom - gridRect.top;

        linesSvg.setAttribute('viewBox', '0 0 ' + gridRect.width + ' ' + gridRect.height);
        linesSvg.setAttribute('width', gridRect.width);
        linesSvg.setAttribute('height', gridRect.height);
        linesSvg.innerHTML = '';

        // Vertical bezier — control points pulled up/down
        function vCurve(x1, y1, x2, y2) {
          const my = (y1 + y2) / 2;
          return 'M ' + x1 + ' ' + y1 + ' C ' + x1 + ' ' + my + ', ' + x2 + ' ' + my + ', ' + x2 + ' ' + y2;
        }

        function addLine(x1, y1, x2, y2, side) {
          const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
          path.setAttribute('d', vCurve(x1, y1, x2, y2));
          path.setAttribute('class', 'bhq-flow-line bhq-flow-line-' + side);
          path.setAttribute('fill', 'none');
          const len = path.getTotalLength ? Math.max(200, Math.ceil(path.getTotalLength())) : 600;
          path.setAttribute('stroke-dasharray', String(len));
          path.setAttribute('stroke-dashoffset', String(reduceMotion ? 0 : len));
          linesSvg.appendChild(path);
          return path;
        }

        const inputPaths = [];
        inputNodes.forEach(function (n) {
          const r = n.getBoundingClientRect();
          const x = (r.left + r.width / 2) - gridRect.left;
          const y = r.bottom - gridRect.top;
          inputPaths.push(addLine(x, y, starInX, starInY, 'in'));
        });
        const outputPaths = [];
        outputNodes.forEach(function (n) {
          const r = n.getBoundingClientRect();
          const x = (r.left + r.width / 2) - gridRect.left;
          const y = r.top - gridRect.top;
          outputPaths.push(addLine(starOutX, starOutY, x, y, 'out'));
        });

        return { inputPaths: inputPaths, outputPaths: outputPaths };
      }

      let drawn = rebuildLines();

      // Wire input / output hover to highlight matching line.
      // Handlers look up the current path each time so they survive resize rebuilds.
      function attachHighlight(nodes, kind) {
        nodes.forEach(function (n, i) {
          function on() {
            if (!drawn) return;
            const arr = kind === 'in' ? drawn.inputPaths : drawn.outputPaths;
            if (arr && arr[i]) arr[i].classList.add('is-highlighted');
          }
          function off() {
            if (!drawn) return;
            const arr = kind === 'in' ? drawn.inputPaths : drawn.outputPaths;
            if (arr && arr[i]) arr[i].classList.remove('is-highlighted');
          }
          n.addEventListener('mouseenter', on);
          n.addEventListener('mouseleave', off);
          n.addEventListener('focus', on);
          n.addEventListener('blur', off);
        });
      }
      attachHighlight(inputNodes, 'in');
      attachHighlight(outputNodes, 'out');

      function animateLines() {
        if (!drawn || reduceMotion) return;
        const allPaths = [].concat(drawn.inputPaths || [], drawn.outputPaths || []);
        allPaths.forEach(function (p, i) {
          setTimeout(function () {
            p.style.transition = 'stroke-dashoffset 1.4s cubic-bezier(0.16, 1, 0.3, 1)';
            p.setAttribute('stroke-dashoffset', '0');
          }, i * 80);
        });
      }

      let triggered = false;
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting && !triggered) {
              triggered = true;
              animateLines();
            }
          });
        }, { threshold: 0.2 });
        io.observe(root);
      } else {
        animateLines();
      }

      let rT;
      window.addEventListener('resize', function () {
        clearTimeout(rT);
        rT = setTimeout(function () {
          drawn = rebuildLines();
          if (triggered && drawn) {
            const allPaths = [].concat(drawn.inputPaths || [], drawn.outputPaths || []);
            allPaths.forEach(function (p) { p.setAttribute('stroke-dashoffset', '0'); });
          }
        }, 200);
      });

      function activate(key) {
        petals.forEach(function (p) {
          p.classList.toggle('is-active', p.getAttribute('data-petal') === key);
        });
        spokes.forEach(function (s) {
          s.classList.toggle('is-active', s.getAttribute('data-petal-spoke') === key);
        });
        if (featurePanel) {
          featurePanel.querySelectorAll('[data-feature]').forEach(function (f) {
            const on = f.getAttribute('data-feature') === key;
            f.classList.toggle('is-active', on);
            f.setAttribute('aria-hidden', on ? 'false' : 'true');
          });
        }
      }

      petals.forEach(function (p) {
        const key = p.getAttribute('data-petal');
        p.addEventListener('mouseenter', function () { activate(key); });
        p.addEventListener('focus', function () { activate(key); });
        p.addEventListener('click', function () { activate(key); });
        p.addEventListener('keydown', function (e) {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            activate(key);
          }
        });
      });
    })();
  </script>





  <!-- ─── ALREADY HAVE TOOLS ─── -->
  <section class="bhq-stack section-alt">
    <div class="bhq-stack-inner">
      <h2 class="scroll-reveal">{stack.header}</h2>
      <p class="bhq-stack-body scroll-reveal">{stack.body}</p>
      <ul class="bhq-stack-list">
        {stack.bringIns.map((item, i) => (
          <li class="scroll-reveal" style={`--i:${i}`}>
            <span class="bhq-stack-arrow" aria-hidden="true">→</span>
            <div>
              <strong>{item.label}</strong>
              <span>{item.detail}</span>
            </div>
          </li>
        ))}
      </ul>
      <p class="bhq-stack-closing scroll-reveal">{stack.closing}</p>
    </div>
  </section>

  <!-- ─── WHO'S USING IT (header above pills band) ─── -->
  <section class="bhq-whos">
    <div class="bhq-whos-inner">
      <header class="bhq-whos-header scroll-reveal">
        <h2>{whosUsing.header}</h2>
        <p class="bhq-whos-body">{whosUsing.body}</p>
      </header>
    </div>
  </section>
  <ClientBand />

  <!-- ─── FAQ (objection handling + GEO/SEO) ─── -->
  <section class="bhq-faq section-alt">
    <div class="bhq-faq-inner">
      <header class="bhq-faq-header scroll-reveal">
        <p class="bhq-section-eyebrow">{faq.eyebrow}</p>
        <h2>{faq.header}</h2>
      </header>
      <div class="bhq-faq-list">
        {faq.items.map((item: any, i: number) => (
          <details class="bhq-faq-item scroll-reveal" style={`--i:${i}`} open={i === 0}>
            <summary>
              <span class="bhq-faq-q">{item.q}</span>
              <span class="bhq-faq-icon" aria-hidden="true"></span>
            </summary>
            <p class="bhq-faq-a">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── PULL QUOTE ─── -->
  <section class="bhq-quote">
    <div class="bhq-quote-inner">
      <figure class="scroll-reveal">
        <span class="bhq-quote-glyph" aria-hidden="true">&ldquo;</span>
        <blockquote>{quote.text}</blockquote>
        <figcaption>
          <span class="bhq-quote-rule" aria-hidden="true"></span>
          {quote.attribution}
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- ─── FINAL CTA ─── -->
  <section class="bhq-final">
    <div class="bhq-final-inner">
      <h2 class="scroll-reveal">{finalCta.header}</h2>
      <p class="scroll-reveal">{finalCta.body}</p>
      <div class="bhq-final-ctas scroll-reveal">
        <a class="btn btn-primary btn-lg" onclick={finalCta.cta_primary_action} style="cursor:pointer">{finalCta.cta_primary} →</a>
        <a class="btn btn-ghost btn-lg" onclick={finalCta.cta_secondary_action} style="cursor:pointer">{finalCta.cta_secondary} →</a>
      </div>
    </div>
  </section>

</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ChampionsKit from '@/components/ChampionsKit.astro';
import sData from '@/data/services.yaml';

const {
  meta,
  referenceBrand,
  hero,
  why,
  modes,
  phases,
  team,
  handoff,
  examples,
  faq,
  finalCta,
  championKit,
} = sData;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.items.map((item: any) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a },
  })),
};
---

<BaseLayout title={meta.title} description={meta.description} ogTitle={meta.ogTitle} ogDescription={meta.ogDescription}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>

  <!-- ─── HERO ─── -->
  <section class="sv-hero">
    <div class="sv-hero-glow" aria-hidden="true"></div>
    <div class="sv-hero-inner">
      <div class="sv-hero-text">
        <p class="sv-eyebrow">{hero.eyebrow}</p>
        <h1>
          <span class="sv-hero-lead">{hero.headline_lead}</span>
          <em>{hero.headline_emphasis}</em>
        </h1>
        <p class="sv-hero-sub">{hero.subhead}</p>
        <div class="sv-hero-ctas">
          <a class="btn btn-primary btn-lg" onclick={hero.cta_primary_action} style="cursor:pointer">{hero.cta_primary} →</a>
          <a class="btn btn-outline btn-lg" href={hero.cta_secondary_href}>{hero.cta_secondary} →</a>
        </div>
      </div>
      <div class="sv-hero-visual" aria-hidden="true">
        <div class="sv-orbit">
          <div class="sv-orbit-ring sv-orbit-ring-outer"></div>
          <div class="sv-orbit-ring sv-orbit-ring-inner"></div>
          <div class="sv-orbit-core">
            <span class="sv-orbit-core-eyebrow">{referenceBrand}</span>
            <strong>Brand HQ</strong>
            <em>The product</em>
          </div>
          <div class="sv-orbit-node sv-orbit-node-1">
            <span class="sv-orbit-num">01</span>
            <strong>The System</strong>
          </div>
          <div class="sv-orbit-node sv-orbit-node-2">
            <span class="sv-orbit-num">02</span>
            <strong>Done For You</strong>
          </div>
          <div class="sv-orbit-node sv-orbit-node-3 is-emphasized">
            <span class="sv-orbit-num">03</span>
            <strong>System + Studio</strong>
            <em>Most clients land here</em>
          </div>
          <div class="sv-orbit-node sv-orbit-node-4">
            <span class="sv-orbit-num">04</span>
            <strong>Embedded</strong>
          </div>
        </div>
        <p class="sv-hero-caption">{hero.visual_caption}</p>
      </div>
    </div>
  </section>

  <!-- ─── WHY ─── -->
  <section class="sv-why sv-section-tint">
    <div class="sv-wave sv-wave-top" aria-hidden="true">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none">
        <path d="M0,12 C280,68 560,4 880,40 C1100,64 1280,28 1440,18 L1440,80 L0,80 Z"/>
      </svg>
    </div>
    <div class="sv-why-inner">
      <header class="sv-why-header scroll-reveal">
        <p class="sv-section-eyebrow">Why this works the way it works</p>
        <h2>{why.header}</h2>
        <p class="sv-why-body">{why.body}</p>
      </header>

      <!-- Wrong shapes vs right shape — visual model-fit diagram -->
      <div class="sv-fit scroll-reveal" aria-hidden="true">
        <div class="sv-fit-row sv-fit-row-wrong">
          <span class="sv-fit-row-label">Most engagement shapes</span>
          <div class="sv-fit-blocks">
            <div class="sv-fit-block sv-fit-block-wrong">
              <span class="sv-fit-glyph"><span class="sv-fit-rect"></span></span>
              <strong>Agency</strong>
              <em>Contracts deliverables</em>
            </div>
            <div class="sv-fit-block sv-fit-block-wrong">
              <span class="sv-fit-glyph">
                <span class="sv-fit-seat"></span><span class="sv-fit-seat"></span><span class="sv-fit-seat"></span>
              </span>
              <strong>SaaS tool</strong>
              <em>Contracts seats</em>
            </div>
            <div class="sv-fit-block sv-fit-block-wrong">
              <span class="sv-fit-glyph"><span class="sv-fit-clock"></span></span>
              <strong>Consultant</strong>
              <em>Contracts hours</em>
            </div>
          </div>
        </div>
        <div class="sv-fit-divider" aria-hidden="true">
          <span class="sv-fit-divider-line"></span>
          <span class="sv-fit-divider-label">none of these fit the work</span>
          <span class="sv-fit-divider-line"></span>
        </div>
        <div class="sv-fit-row sv-fit-row-right">
          <span class="sv-fit-row-label">The shape brand actually needs</span>
          <div class="sv-fit-block sv-fit-block-right">
            <span class="sv-fit-glyph sv-fit-glyph-hq" aria-hidden="true">
              <span class="sv-fit-orbit"></span>
              <span class="sv-fit-core">HQ</span>
            </span>
            <strong>Foundation that compounds</strong>
            <em>+ execution that scales · + partnership when called for</em>
          </div>
        </div>
      </div>

      {why.closing && (
        <p class="sv-why-closing scroll-reveal">
          <span class="sv-why-mark" aria-hidden="true">↑</span>
          {why.closing}
        </p>
      )}
    </div>
  </section>

  <!-- ─── FOUR MODES ─── -->
  <section class="sv-modes">
    <div class="sv-modes-inner">
      <header class="sv-modes-header scroll-reveal">
        <h2>{modes.header}</h2>
        <p class="sv-modes-sub">{modes.subhead}</p>
      </header>
      <div class="sv-modes-grid">
        {modes.cards.map((card: any, i: number) => (
          <article
            class={`sv-mode sv-mode-${card.id} ${card.emphasized ? 'is-emphasized' : ''} ${card.isPartnership ? 'is-partnership' : ''} scroll-reveal`}
            style={`--i:${i}`}
          >
            {card.emphasized && (
              <span class="sv-mode-badge">
                <span class="sv-mode-badge-dot" aria-hidden="true"></span>
                {card.emphasisLabel}
              </span>
            )}
            {card.isPartnership && (
              <span class="sv-mode-badge sv-mode-badge-partnership">
                Partnership shape
              </span>
            )}
            <div class="sv-mode-shape" aria-hidden="true">
              {card.id === 'system' && (
                <div class="sv-shape sv-shape-system">
                  <div class="sv-shape-block sv-shape-block-us">
                    <span class="sv-shape-mark">SS</span>
                    <em>Builds</em>
                  </div>
                  <span class="sv-shape-arrow">
                    <svg viewBox="0 0 60 12" preserveAspectRatio="none">
                      <line x1="2" y1="6" x2="54" y2="6"/>
                      <polyline points="48,2 58,6 48,10"/>
                    </svg>
                    <em>Hands off</em>
                  </span>
                  <div class="sv-shape-block sv-shape-block-them is-primary">
                    <span class="sv-shape-mark sv-shape-mark-hq">HQ</span>
                    <em>Your team owns + runs</em>
                  </div>
                </div>
              )}
              {card.id === 'doneforyou' && (
                <div class="sv-shape sv-shape-doneforyou">
                  <div class="sv-shape-fused">
                    <span class="sv-shape-mark sv-shape-mark-fused">SS · HQ</span>
                    <em>We run it</em>
                  </div>
                  <div class="sv-shape-out">
                    <span class="sv-shape-rays" aria-hidden="true">
                      <span></span><span></span><span></span><span></span><span></span>
                    </span>
                    <em>Active execution</em>
                  </div>
                </div>
              )}
              {card.id === 'both' && (
                <div class="sv-shape sv-shape-both">
                  <div class="sv-shape-block sv-shape-block-them is-primary">
                    <span class="sv-shape-mark sv-shape-mark-hq">HQ</span>
                    <em>Your team owns it</em>
                  </div>
                  <span class="sv-shape-orbit" aria-hidden="true">
                    <svg viewBox="0 0 56 56">
                      <circle cx="28" cy="28" r="22" fill="none" stroke="currentColor" stroke-width="1.2" stroke-dasharray="3 3"/>
                      <circle cx="28" cy="6" r="3" fill="currentColor"/>
                    </svg>
                    <em>Retainer</em>
                  </span>
                  <div class="sv-shape-block sv-shape-block-us">
                    <span class="sv-shape-mark">SS</span>
                    <em>In moments</em>
                  </div>
                </div>
              )}
              {card.id === 'embedded' && (
                <div class="sv-shape sv-shape-embedded">
                  <div class="sv-shape-outer">
                    <em class="sv-shape-outer-label">Your fund · program · stack</em>
                    <div class="sv-shape-inner">
                      <span class="sv-shape-mark sv-shape-mark-fused">SS · HQ</span>
                      <em>Embedded inside</em>
                    </div>
                  </div>
                </div>
              )}
            </div>
            <div class="sv-mode-head">
              <span class="sv-mode-num">{card.number}</span>
              <h3>{card.name}</h3>
            </div>
            <p class="sv-mode-claim">{card.claim}</p>
            <div class="sv-mode-meta">
              <span class="sv-mode-for">For: {card.forTag}</span>
              {card.timing && (
                <span class="sv-mode-timing">
                  <span class="sv-mode-timing-dot" aria-hidden="true"></span>
                  {card.timing}
                </span>
              )}
            </div>
            <ul class="sv-mode-list">
              {card.whatsInIt.map((item: string) => (
                <li>
                  <span class="sv-mode-check" aria-hidden="true">
                    <svg viewBox="0 0 14 14" fill="none">
                      <path d="M3 7.5 L6 10.5 L11 4.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <a class="sv-mode-cta" onclick="openModal()" style="cursor:pointer">{card.cta} →</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── THREE PHASES (rail) ─── -->
  <section class="sv-phases sv-section-grid">
    <div class="sv-phases-inner">
      <header class="sv-phases-header scroll-reveal">
        <p class="sv-section-eyebrow">What an engagement looks like</p>
        <h2>{phases.header}</h2>
        {phases.subhead && <p class="sv-phases-sub">{phases.subhead}</p>}
      </header>
      <ol class="sv-phases-rail" aria-label="Engagement phases">
        <span class="sv-phases-rail-line" aria-hidden="true"></span>
        {phases.cards.map((p: any, i: number) => (
          <li class="sv-phase-node scroll-reveal" style={`--i:${i}`}>
            <span class="sv-phase-num">{p.num}</span>
            <h3>{p.name}</h3>
            <p>{p.what}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ─── WHO IS IN THE ROOM ─── -->
  <section class="sv-team">
    <div class="sv-team-inner scroll-reveal">
      <p class="sv-section-eyebrow">Who's in the room</p>
      <h2>{team.header}</h2>
      <p>{team.body}</p>
    </div>
  </section>

  <!-- ─── HANDOFF / KEEP RUNNING (matrix) ─── -->
  <section class="sv-handoff sv-section-tint">
    <div class="sv-wave sv-wave-top" aria-hidden="true">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none">
        <path d="M0,12 C280,68 560,4 880,40 C1100,64 1280,28 1440,18 L1440,80 L0,80 Z"/>
      </svg>
    </div>
    <div class="sv-handoff-inner">
      <header class="sv-handoff-header scroll-reveal">
        <p class="sv-section-eyebrow">What you keep</p>
        <h2>{handoff.header}</h2>
        <p class="sv-handoff-body">{handoff.body}</p>
      </header>
      <p class="sv-matrix-hint" aria-hidden="true">Swipe to compare modes</p>
      <div class="sv-matrix-wrap scroll-reveal">
        <table class="sv-matrix" role="table">
          <thead>
            <tr>
              <th scope="col" class="sv-matrix-row-head"><span class="sv-mat-empty">Capability</span></th>
              {handoff.modesHeader.slice(1).map((m: string) => (
                <th scope="col" class={`sv-matrix-mode ${m === 'System + Studio' ? 'is-emphasized' : ''}`}>
                  <span>{m}</span>
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {handoff.rows.map((row: any, i: number) => {
              const isFirstRunning = row.group === 'running' && handoff.rows[i - 1]?.group === 'handoff';
              return (
                <>
                  {isFirstRunning && (
                    <tr class="sv-matrix-divider" aria-hidden="true">
                      <td colspan={5}>
                        <span class="sv-matrix-divider-label">{handoff.legend.runningLabel}</span>
                      </td>
                    </tr>
                  )}
                  {i === 0 && (
                    <tr class="sv-matrix-divider" aria-hidden="true">
                      <td colspan={5}>
                        <span class="sv-matrix-divider-label sv-matrix-divider-handoff">{handoff.legend.handoffLabel}</span>
                      </td>
                    </tr>
                  )}
                  <tr class={`sv-matrix-row sv-matrix-row-${row.group}`}>
                    <th scope="row" class="sv-matrix-row-head">{row.label}</th>
                    {row.values.map((v: any, vi: number) => (
                      <td class={`sv-matrix-cell ${vi === 2 ? 'is-emphasized' : ''}`}>
                        {v === true && (
                          <span class="sv-matrix-check" aria-label="Included">
                            <svg viewBox="0 0 14 14" fill="none">
                              <path d="M3 7.5 L6 10.5 L11 4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                          </span>
                        )}
                        {v === false && (
                          <span class="sv-matrix-dash" aria-label="Not included">—</span>
                        )}
                        {v === 'moments' && (
                          <span class="sv-matrix-moments" aria-label="On retainer or per-engagement, when the moment calls for it">
                            moments
                          </span>
                        )}
                      </td>
                    ))}
                  </tr>
                </>
              );
            })}
          </tbody>
        </table>
        <p class="sv-matrix-note">{handoff.legend.momentsNote}</p>
      </div>
    </div>
  </section>

  <!-- ─── EXAMPLES IN PRACTICE ─── -->
  <section class="sv-examples sv-section-deep">
    <div class="sv-examples-inner">
      <header class="sv-examples-header scroll-reveal">
        <p class="sv-section-eyebrow">In practice</p>
        <h2>{examples.header}</h2>
      </header>
      <div class="sv-examples-list">
        {examples.cards.map((ex: any, i: number) => (
          <article class="sv-example scroll-reveal" style={`--i:${i}`}>
            <span class="sv-example-tag">{ex.tag}</span>
            <div class="sv-example-text">
              {ex.pull && <p class="sv-example-pull">{ex.pull}</p>}
              <p class="sv-example-body">{ex.body}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── FAQ ─── -->
  <section class="sv-faq sv-section-tint">
    <div class="sv-faq-inner">
      <header class="sv-faq-header scroll-reveal">
        <p class="sv-section-eyebrow">{faq.eyebrow}</p>
        <h2>{faq.header}</h2>
      </header>
      <div class="sv-faq-list">
        {faq.items.map((item: any, i: number) => (
          <details class="sv-faq-item scroll-reveal" style={`--i:${i}`} open={i === 0}>
            <summary>
              <span class="sv-faq-q">{item.q}</span>
              <span class="sv-faq-icon" aria-hidden="true"></span>
            </summary>
            <p class="sv-faq-a">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── FINAL CTA ─── -->
  <section class="sv-final">
    <div class="sv-final-glow" aria-hidden="true"></div>
    <div class="sv-final-inner">
      <h2 class="scroll-reveal">{finalCta.header}</h2>
      <p class="scroll-reveal">{finalCta.body}</p>
      <div class="sv-final-ctas scroll-reveal">
        <a class="btn btn-primary btn-lg" onclick={finalCta.cta_primary_action} style="cursor:pointer">{finalCta.cta_primary} →</a>
        <a class="btn btn-ghost btn-lg" onclick={finalCta.cta_secondary_action} style="cursor:pointer">{finalCta.cta_secondary} →</a>
      </div>
    </div>
  </section>

  <ChampionsKit
    closedLabel={championKit.closedLabel}
    microcopy={championKit.microcopy}
    items={championKit.items}
    href={championKit.href}
  />

</BaseLayout>

---
import footerData from '@/data/footer.yaml';

const { brand, columns, bottom } = footerData;
---

<footer>
  <div class="footer-inner">
    <div class="footer-top">
      <div>
        <a href="/" class="nav-logo footer-logo" style="pointer-events:auto;cursor:pointer;text-decoration:none">
          <img src="/images/logo-full-dark.png" alt="StartSuite" class="footer-logo-img" />
        </a>
        <p class="footer-tagline">{brand.tagline}</p>
      </div>
      <div class="footer-cols">
        {columns.map((col: any) => (
          <div class="footer-col">
            <h5>{col.title}</h5>
            <ul>
              {col.links.map((link: any) => (
                <li>
                  {link.action
                    ? <a onclick={link.action} style="cursor:pointer">{link.label}</a>
                    : <a href={link.href}>{link.label}</a>
                  }
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
    <div class="footer-powered">
      <p>{bottom.powered_by}</p>
    </div>
    <div class="footer-bottom">
      <p>{bottom.copyright}</p>
      {bottom.legal && (
        <div class="footer-legal">
          {bottom.legal.map((item: any, i: number) => (
            <>
              {i > 0 && <span class="footer-legal-dot">·</span>}
              <a href={item.href}>{item.label}</a>
            </>
          ))}
        </div>
      )}
    </div>
  </div>
</footer>

---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const forYouItems = [
  {
    href: '/for-founders',
    label: 'For Founders',
    description: 'A brand foundation built in weeks. Yours from day one.',
    icon: 'founders',
  },
  {
    href: '/for-operators',
    label: 'For Operators',
    sublabel: 'Marketing Teams',
    description: 'The brand operating system for CMOs running real complexity.',
    icon: 'operators',
  },
  {
    href: '/for-partners',
    label: 'For Partners',
    description: 'Brand infrastructure for VCs, accelerators, and ecosystem partners.',
    icon: 'partners',
  },
];

const links = [
  { href: '/brand-hq', label: 'Brand HQ', id: 'nav-brand-hq' },
  { type: 'dropdown', label: 'For You', id: 'nav-for-you', items: forYouItems },
  { href: '/services', label: 'Services', id: 'nav-services' },
  { href: '/about', label: 'About', id: 'nav-about' },
] as const;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/' || currentPath === '';
  return currentPath.startsWith(href);
}

function isAnyChildActive(items: readonly { href: string }[]): boolean {
  return items.some(i => isActive(i.href));
}
---

<nav>
  <div class="nav-left">
    <a href="/" class="nav-logo" style="text-decoration:none"><img src="/images/logo-icon.png" alt="StartSuite" class="nav-mark-img" />StartSuite</a>
    <div class="nav-powered">A partner of <span>46Capital</span></div>
  </div>
  <ul class="nav-links">
    {links.map(link => (
      <li class={link.type === 'dropdown' ? 'has-dropdown' : ''}>
        {link.type === 'dropdown' ? (
          <>
            <button
              type="button"
              id={link.id}
              class={`nav-dropdown-trigger ${isAnyChildActive(link.items) ? 'active' : ''}`}
              aria-haspopup="true"
              aria-expanded="false"
              data-dropdown-trigger
            >
              {link.label}
              <svg class="nav-caret" viewBox="0 0 12 8" aria-hidden="true">
                <path d="M2 2 L6 6 L10 2" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="nav-mega" role="menu" data-dropdown-menu>
              <p class="nav-mega-label">Pick the path that fits you</p>
              <div class="nav-mega-grid">
                {link.items.map((sub: any) => (
                  <a
                    href={sub.href}
                    role="menuitem"
                    class={`nav-mega-card ${isActive(sub.href) ? 'is-active' : ''}`}
                  >
                    <span class="nav-mega-icon" aria-hidden="true">
                      {sub.icon === 'founders' && (
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M12 2 L14.5 9 L22 9 L16 13.5 L18.5 21 L12 16.5 L5.5 21 L8 13.5 L2 9 L9.5 9 Z"/>
                        </svg>
                      )}
                      {sub.icon === 'operators' && (
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                          <rect x="3" y="3" width="7" height="7"/>
                          <rect x="14" y="3" width="7" height="7"/>
                          <rect x="3" y="14" width="7" height="7"/>
                          <rect x="14" y="14" width="7" height="7"/>
                        </svg>
                      )}
                      {sub.icon === 'partners' && (
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                          <circle cx="12" cy="12" r="3"/>
                          <circle cx="5" cy="5" r="2"/>
                          <circle cx="19" cy="5" r="2"/>
                          <circle cx="5" cy="19" r="2"/>
                          <circle cx="19" cy="19" r="2"/>
                          <path d="M9.5 9.5 L6.5 6.5 M14.5 9.5 L17.5 6.5 M9.5 14.5 L6.5 17.5 M14.5 14.5 L17.5 17.5" opacity="0.5"/>
                        </svg>
                      )}
                    </span>
                    <div class="nav-mega-text">
                      <strong>
                        {sub.label}
                        {sub.sublabel && <em class="nav-mega-sublabel">/ {sub.sublabel}</em>}
                      </strong>
                      <span>{sub.description}</span>
                    </div>
                    <span class="nav-mega-arrow" aria-hidden="true">→</span>
                  </a>
                ))}
              </div>
            </div>
          </>
        ) : (
          <a href={link.href} id={link.id} class={isActive(link.href) ? 'active' : ''}>
            {link.label}
          </a>
        )}
      </li>
    ))}
  </ul>
  <div class="nav-cta">
    <a class="btn btn-primary" onclick="openModal()">Book Intro</a>
  </div>
  <button class="nav-hamburger" onclick="toggleMobileNav()" aria-label="Toggle menu">
    <span></span><span></span><span></span>
  </button>
</nav>
<div class="nav-mobile-overlay" onclick="toggleMobileNav()"></div>
<div class="nav-mobile-menu">
  <ul>
    {links.map(link => (
      link.type === 'dropdown' ? (
        <>
          <li class="nav-mobile-group-label">{link.label}</li>
          {link.items.map((sub: any) => (
            <li>
              <a href={sub.href} class={`nav-mobile-sub ${isActive(sub.href) ? 'active' : ''}`}>
                {sub.label}
              </a>
            </li>
          ))}
        </>
      ) : (
        <li>
          <a href={link.href} class={isActive(link.href) ? 'active' : ''}>
            {link.label}
          </a>
        </li>
      )
    ))}
  </ul>
  <a class="btn btn-primary btn-full" onclick="openModal();toggleMobileNav()">Book Intro</a>
</div>

<script is:inline>
  (function () {
    const trigger = document.querySelector('[data-dropdown-trigger]');
    const menu = document.querySelector('[data-dropdown-menu]');
    if (!trigger || !menu) return;
    const wrap = trigger.closest('.has-dropdown');

    function open() {
      wrap.classList.add('is-open');
      trigger.setAttribute('aria-expanded', 'true');
    }
    function close() {
      wrap.classList.remove('is-open');
      trigger.setAttribute('aria-expanded', 'false');
    }

    trigger.addEventListener('click', function (e) {
      e.stopPropagation();
      if (wrap.classList.contains('is-open')) close(); else open();
    });
    trigger.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') close();
    });
    if (window.matchMedia && window.matchMedia('(hover: hover)').matches) {
      wrap.addEventListener('mouseenter', open);
      wrap.addEventListener('mouseleave', close);
    }
    document.addEventListener('click', function (e) {
      if (!wrap.contains(e.target)) close();
    });
  })();
</script>

---
interface KitItem {
  label: string;
  detail: string;
}
interface Props {
  closedLabel: string;
  microcopy: string;
  items: KitItem[];
  href: string;
}
const { closedLabel, microcopy, items, href } = Astro.props;
---

<aside class="ck" data-champions-kit aria-label="Champion's Kit">
  <button
    type="button"
    class="ck-trigger"
    data-ck-toggle
    aria-expanded="false"
    aria-controls="ck-panel"
  >
    <span class="ck-trigger-icon" aria-hidden="true">
      <svg viewBox="0 0 16 16" fill="none">
        <path d="M3 4 L13 4 L13 13 C13 13.5 12.5 14 12 14 L4 14 C3.5 14 3 13.5 3 13 Z" stroke="currentColor" stroke-width="1.4"/>
        <path d="M5.5 4 V2.5 C5.5 2 6 1.5 6.5 1.5 H9.5 C10 1.5 10.5 2 10.5 2.5 V4" stroke="currentColor" stroke-width="1.4"/>
      </svg>
    </span>
    <span class="ck-trigger-text">
      <strong>{closedLabel}</strong>
      <span>{microcopy}</span>
    </span>
    <span class="ck-trigger-arrow" aria-hidden="true">→</span>
  </button>

  <div class="ck-panel" id="ck-panel" data-ck-panel role="region">
    <div class="ck-panel-head">
      <p class="ck-panel-eyebrow">{closedLabel}</p>
      <button type="button" class="ck-close" data-ck-close aria-label="Close Champion's Kit">×</button>
    </div>
    <p class="ck-panel-microcopy">{microcopy}</p>
    <ul class="ck-list">
      {items.map((item) => (
        <li>
          <a href={href}>
            <strong>{item.label}</strong>
            <span>{item.detail}</span>
          </a>
        </li>
      ))}
    </ul>
    <a class="ck-panel-cta" href={href}>See the full kit →</a>
  </div>
</aside>

<script is:inline>
  (function () {
    const root = document.querySelector('[data-champions-kit]');
    if (!root) return;
    const trigger = root.querySelector('[data-ck-toggle]');
    const close = root.querySelector('[data-ck-close]');
    const panel = root.querySelector('[data-ck-panel]');

    const STORAGE_KEY = 'startsuite_ck_dismissed_v1';
    if (sessionStorage.getItem(STORAGE_KEY) === '1') {
      root.style.display = 'none';
      return;
    }

    // Reveal after hero scroll
    function maybeReveal() {
      if (window.scrollY > 400) {
        root.classList.add('is-revealed');
      }
    }
    maybeReveal();
    window.addEventListener('scroll', maybeReveal, { passive: true });

    function open() {
      root.classList.add('is-open');
      trigger.setAttribute('aria-expanded', 'true');
    }
    function shut() {
      root.classList.remove('is-open');
      trigger.setAttribute('aria-expanded', 'false');
    }

    trigger.addEventListener('click', function () {
      root.classList.contains('is-open') ? shut() : open();
    });
    close.addEventListener('click', function (e) {
      e.stopPropagation();
      sessionStorage.setItem(STORAGE_KEY, '1');
      root.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
      root.style.opacity = '0';
      root.style.transform = 'translateY(20px)';
      setTimeout(function () { root.style.display = 'none'; }, 300);
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && root.classList.contains('is-open')) shut();
    });
    document.addEventListener('click', function (e) {
      if (!root.contains(e.target) && root.classList.contains('is-open')) shut();
    });
  })();
</script>

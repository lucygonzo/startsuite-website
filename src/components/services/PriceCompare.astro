---
import servicesData from '@/data/services.yaml';

const { priceCompare } = servicesData;
---

<div class="dim-line"><span class="dim-line-label">{priceCompare.dimLineLabel}</span></div>

<div class="f-compare-wrap section-alt">
  <div class="f-compare">
    <div class="f-compare-header scroll-reveal">
      <div>
        <div class="pill">{priceCompare.pill}</div>
        <h2 set:html={priceCompare.headline} />
      </div>
      <p>{priceCompare.description}</p>
    </div>
    <div class="f-compare-table">
      {priceCompare.rows.map((row: any) => (
        <div class={row.highlight ? 'f-compare-row-hi scroll-reveal' : 'f-compare-row scroll-reveal'}>
          <div class="f-compare-who">{row.who}</div>
          <div class="f-compare-cost" set:html={row.cost} />
          <div class="f-compare-desc">{row.desc}</div>
        </div>
      ))}
    </div>
    <div class="f-compare-strip scroll-reveal">
      {priceCompare.tags.map((tag: string) => (
        <span class="f-compare-tag">{tag}</span>
      ))}
    </div>
  </div>
</div>

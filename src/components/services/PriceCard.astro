---
import servicesData from '@/data/services.yaml';

const { priceCard } = servicesData;
---

  <div>
    <div class="price-card scroll-reveal">
      <div class="price-badge">{priceCard.badge}</div>
      <div class="price-amount">{priceCard.amount}</div>
      <div class="price-period" set:html={priceCard.period} />
      <div class="price-divider"></div>
      <ul class="price-features">
        {priceCard.features.map((feature: string) => (
          <li set:html={feature} />
        ))}
      </ul>
      <a class="btn btn-primary btn-full btn-lg" onclick="openModal()">{priceCard.cta}</a>
      <p class="price-note">{priceCard.note}</p>
    </div>
  </div>
</div>

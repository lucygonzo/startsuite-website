---
import servicesData from '@/data/services.yaml';

const { timeline } = servicesData;
---

<div class="f-timeline-wrap section-alt">
  <div class="f-timeline-head scroll-reveal">
    <div>
      <div class="pill">{timeline.pill}</div>
      <h2>{timeline.headline}</h2>
    </div>
    <p>{timeline.description}</p>
  </div>
  <div class="dim-line" style="max-width:1200px;margin:0 auto 56px;padding:0 40px"><span class="dim-line-label">{timeline.dimLineLabel}</span></div>
  <div class="f-milestones">
    {timeline.milestones.map((ms: any) => (
      <div class="f-ms scroll-reveal">
        <div class="f-ms-dot">{ms.dot}</div>
        <div class="f-ms-card">
          <div class="f-ms-month">{ms.month}</div>
          <div class="f-ms-title">{ms.title}</div>
          <div class="f-ms-desc">{ms.desc}</div>
        </div>
      </div>
    ))}
  </div>
</div>

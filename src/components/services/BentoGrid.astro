---
import servicesData from '@/data/services.yaml';

const { bentoGrid } = servicesData;
---

<div class="f-bento-wrap" id="f-included">
  <div class="marginalia scroll-reveal" style="margin-bottom:16px">{bentoGrid.marginalia}</div>
  <div class="f-bento-head scroll-reveal">
    <div>
      <div class="pill">{bentoGrid.pill}</div>
      <h2 set:html={bentoGrid.headline} />
    </div>
    <p>{bentoGrid.description}</p>
  </div>
  <div class="f-bento">

    <!-- 01 — Brand Foundation hero -->
    <div class="fb-brand scroll-reveal">
      <div class="fb-brand-left">
        <div class="fb-label">{bentoGrid.brand.label}</div>
        <h3>{bentoGrid.brand.title}</h3>
        <p>{bentoGrid.brand.description}</p>
        <div class="fb-tags">
          {bentoGrid.brand.tags.map((tag: string) => (
            <span class="fb-tag">{tag}</span>
          ))}
        </div>
      </div>
      <div class="fb-brand-right">
        {bentoGrid.brand.milestones.map((ms: any) => (
          <div class="fb-brand-item">
            <span class="fb-brand-item-icon" style="font-size:10px;font-weight:800;color:var(--text-dim)">&rarr;</span>
            <span class="fb-brand-item-label">{ms.label}</span>
            <span class="fb-brand-item-tag">{ms.tag}</span>
          </div>
        ))}
        <div class="fb-insight">{bentoGrid.brand.insight}</div>
      </div>
    </div>

    <!-- 02 / 03 / 04 — three-column -->
    <div class="fb-trio">
      {bentoGrid.trio.map((card: any) => (
        <div class="fb-card scroll-reveal">
          <div class="fb-card-num">{card.num}</div>
          <div class="fb-label">{card.label}</div>
          <h3>{card.title}</h3>
          <p set:html={card.description} />
          <div class="fb-tags">
            {card.tags.map((tag: string) => (
              <span class="fb-tag">{tag}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- 05 — Strategic Support strip -->
    <div class="fb-strip scroll-reveal">
      <div>
        <div class="fb-label">{bentoGrid.strip.label}</div>
        <h3>{bentoGrid.strip.title}</h3>
        <p style="margin-bottom:0">{bentoGrid.strip.description}</p>
      </div>
      <div class="fb-strip-stats">
        {bentoGrid.strip.stats.map((stat: any) => (
          <div class="fb-strip-stat">
            <div class="fb-strip-stat-val">{stat.val}</div>
            <div class="fb-strip-stat-label">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>

  </div>
</div>

---
interface Props {
  num: string;
  label: string;
  target?: number;
  prefix?: string;
  suffix?: string;
  decimal?: boolean;
}
const { num, label, target, prefix = '', suffix = '', decimal = false } = Astro.props;
---
<div class="stat-item">
  {target !== undefined ? (
    <span class="stat-num" data-target={target} data-prefix={prefix || undefined} data-suffix={suffix || undefined} data-decimal={decimal || undefined}>{num}</span>
  ) : (
    <span class="stat-num">{num}</span>
  )}
  <div class="stat-lbl">{label}</div>
</div>

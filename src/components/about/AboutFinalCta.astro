---
import aboutData from '@/data/about.yaml';
const { final_cta } = aboutData;
---

<div class="a-final">
  <div class="pill scroll-reveal" style="margin:0 auto 20px">{final_cta.pill}</div>
  <h2 class="scroll-reveal" style="transition-delay:0.06s" set:html={final_cta.headline} />
  <p class="scroll-reveal" style="transition-delay:0.12s">{final_cta.description}</p>
  <div class="scroll-reveal" style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;transition-delay:0.18s">
    <a class="btn btn-primary btn-lg" href={final_cta.cta_primary.href}>{final_cta.cta_primary.label}</a>
    <a class="btn btn-outline btn-lg" href="/intake">{final_cta.cta_outline.label}</a>
  </div>
</div>

---
import homeData from '@/data/home.yaml';

const { proofBar } = homeData;

function applyHighlight(quote: string, highlight?: string): string {
  if (!highlight) return quote;
  const idx = quote.toLowerCase().indexOf(highlight.toLowerCase());
  if (idx < 0) return quote;
  const before = quote.slice(0, idx);
  const match = quote.slice(idx, idx + highlight.length);
  const after = quote.slice(idx + highlight.length);
  return `${before}<mark class="proof-emphasis">${match}</mark>${after}`;
}
---

<section class="proof-bar-wrap section-alt">
  <div class="proof-bar-inner">
    <p class="proof-bar-header marginalia">{proofBar.header}</p>
    <div class="proof-stage" data-proof>
      <div class="proof-featured" data-proof-featured>
        {proofBar.quotes.map((q: any, i: number) => (
          <figure
            class={`proof-featured-quote ${i === 0 ? 'is-active' : ''}`}
            data-proof-slot={i}
            aria-hidden={i === 0 ? 'false' : 'true'}
          >
            <span class="proof-quote-glyph" aria-hidden="true">&ldquo;</span>
            <blockquote set:html={applyHighlight(q.quote, q.highlight)} />
            <figcaption>
              <span class="proof-cite-rule" aria-hidden="true"></span>
              {q.attribution}
            </figcaption>
          </figure>
        ))}
      </div>

      <ol class="proof-pager" role="tablist" aria-label="Other quotes">
        {proofBar.quotes.map((q: any, i: number) => (
          <li>
            <button
              type="button"
              class={`proof-pager-item ${i === 0 ? 'is-active' : ''}`}
              data-proof-card={i}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
            >
              <span class="proof-pager-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="proof-pager-meta">
                <span class="proof-pager-attribution">{q.attribution}</span>
                {q.highlight && (
                  <span class="proof-pager-teaser">&ldquo;{q.highlight}&rdquo;</span>
                )}
              </span>
            </button>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const stage = document.querySelector('[data-proof]');
    if (!stage) return;
    const slots = stage.querySelectorAll('[data-proof-slot]');
    const cards = stage.querySelectorAll('[data-proof-card]');
    if (!slots.length) return;

    let active = 0;
    let timer = null;
    const INTERVAL = 8000;

    function go(next) {
      if (next === active) return;
      next = (next + slots.length) % slots.length;
      slots.forEach(function (s, i) {
        const on = i === next;
        s.classList.toggle('is-active', on);
        s.setAttribute('aria-hidden', on ? 'false' : 'true');
      });
      cards.forEach(function (c, i) {
        const on = i === next;
        c.classList.toggle('is-active', on);
        c.setAttribute('aria-selected', on ? 'true' : 'false');
      });
      active = next;
    }

    function start() {
      stop();
      timer = setInterval(function () { go(active + 1); }, INTERVAL);
    }
    function stop() { if (timer) { clearInterval(timer); timer = null; } }

    cards.forEach(function (c, i) {
      c.addEventListener('click', function () {
        go(i);
        start();
      });
    });

    const wrap = document.querySelector('.proof-bar-wrap');
    if (wrap) {
      wrap.addEventListener('mouseenter', stop);
      wrap.addEventListener('mouseleave', start);
    }

    if ('IntersectionObserver' in window && wrap) {
      const io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) { e.isIntersecting ? start() : stop(); });
      }, { threshold: 0.25 });
      io.observe(wrap);
    } else {
      start();
    }
  })();
</script>

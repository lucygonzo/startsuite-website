---
import homeData from '@/data/home.yaml';

const { dualPath } = homeData;
---

<section class="dual-path-wrap">
  <div class="dual-path-grid">
    <article class="dp-card scroll-reveal">
      <div class="dp-eyebrow">For {dualPath.cards[0].audience}</div>
      <h3>{dualPath.cards[0].heading}</h3>
      <p>{dualPath.cards[0].copy}</p>
      <a class="dp-cta" href={dualPath.cards[0].href}>{dualPath.cards[0].cta}</a>
    </article>
    <span class="dp-divider" aria-hidden="true"></span>
    <article class="dp-card scroll-reveal">
      <div class="dp-eyebrow">For {dualPath.cards[1].audience}</div>
      <h3>{dualPath.cards[1].heading}</h3>
      <p>{dualPath.cards[1].copy}</p>
      <a class="dp-cta" href={dualPath.cards[1].href}>{dualPath.cards[1].cta}</a>
    </article>
  </div>
</section>

---
import homeData from '@/data/home.yaml';

const { empowerment } = homeData;

const pairs: [string, string][] = empowerment.dont.items.map(
  (d: string, i: number) => [d, empowerment.do.items[i]]
);
---

<section class="emp-wrap section-alt">
  <div class="emp-inner">
    <header class="emp-header scroll-reveal">
      <h2>{empowerment.header}</h2>
      <p class="emp-subhead">{empowerment.subhead}</p>
    </header>

    <p class="emp-body scroll-reveal">{empowerment.body}</p>

    <div class="emp-pairs" data-emp-pairs>
      <div class="emp-pairs-headers">
        <h3 class="emp-col-title">{empowerment.dont.title}</h3>
        <span class="emp-col-arrow" aria-hidden="true"></span>
        <h3 class="emp-col-title">{empowerment.do.title}</h3>
      </div>
      <ul class="emp-pairs-list">
        {pairs.map(([dont, doItem], i) => (
          <li class="emp-pair" style={`--i:${i}`}>
            <span class="emp-pair-dont">{dont}</span>
            <span class="emp-pair-line" aria-hidden="true">
              <svg viewBox="0 0 100 8" preserveAspectRatio="none" class="emp-pair-line-svg">
                <line x1="0" y1="4" x2="100" y2="4" />
                <polyline points="92,1 99,4 92,7" />
              </svg>
            </span>
            <span class="emp-pair-do">{doItem}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="emp-services scroll-reveal">
      <div class="emp-services-head">
        <span class="emp-services-eyebrow">{empowerment.services.eyebrow}</span>
        <h3>{empowerment.services.heading}</h3>
      </div>
      <p class="emp-services-copy">{empowerment.services.copy}</p>
      <ol class="emp-services-modes">
        {empowerment.services.modes.map((m: any, i: number) => (
          <li>
            <span class="emp-services-num">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <h4>{m.title}</h4>
              <p>{m.copy}</p>
            </div>
          </li>
        ))}
      </ol>
      <a class="emp-services-link" href={empowerment.services.href}>{empowerment.services.link} →</a>
    </div>

    <figure class="emp-pull-quote scroll-reveal">
      <span class="emp-pull-glyph" aria-hidden="true">&ldquo;</span>
      <blockquote>{empowerment.pullQuote.quote}</blockquote>
      <figcaption>
        <span class="emp-pull-rule" aria-hidden="true"></span>
        {empowerment.pullQuote.attribution}
      </figcaption>
    </figure>
  </div>
</section>

<script is:inline>
  (function () {
    const wrap = document.querySelector('[data-emp-pairs]');
    if (!wrap) return;
    const reduce = window.matchMedia &&
      window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) {
      wrap.classList.add('is-revealed');
      return;
    }
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) {
            wrap.classList.add('is-revealed');
            io.disconnect();
          }
        });
      }, { threshold: 0.2 });
      io.observe(wrap);
    } else {
      wrap.classList.add('is-revealed');
    }
  })();
</script>

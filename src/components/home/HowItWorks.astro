---
import homeData from '@/data/home.yaml';

const { howItWorks } = homeData;
---

<div class="hiw-wrap">
<div class="hiw-inner">
  <div class="hiw-header scroll-reveal">
    <div>
      <div class="pill">{ howItWorks.pill }</div>
      <h2 set:html={howItWorks.headline} />
    </div>
    <div class="hiw-header-right">
      <p>{ howItWorks.description }</p>
      <div class="hiw-cta-inline">
        <a class="btn btn-primary" href="/intake">{ howItWorks.cta_primary }</a>
        <a class="btn btn-outline" href="/services">{ howItWorks.cta_secondary }</a>
      </div>
    </div>
  </div>
  <div style="position:relative">
    <div class="marginalia" style="position:absolute;top:-18px;right:0" set:html={howItWorks.steps_marginalia} />
  </div>
  <div class="hiw-steps">
    {howItWorks.steps.map((step: any) => (
      <div class="hiw-step scroll-reveal">
        <div class="hiw-step-num">{step.num}</div>
        <div class="hiw-step-content">
          <h4>{step.title}</h4>
          {step.desc && <p>{step.desc}</p>}
          <div class="hiw-tag">{step.tag}</div>
        </div>
      </div>
    ))}
  </div>
  <div class="hiw-timeline">
    <div class="hiw-timeline-line"></div>
    <div class="hiw-timeline-dots">
      {howItWorks.steps.map(() => (
        <div class="hiw-timeline-dot"></div>
      ))}
    </div>
  </div>
</div>
</div>

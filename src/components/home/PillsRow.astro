---
interface PillItem {
  label: string;
  hover: string;
  icon?: string;
}

interface Props {
  pills: PillItem[];
  marginalia?: string;
}

const { pills, marginalia } = Astro.props;

// Duplicate pills for seamless marquee loop
const loop = [...pills, ...pills];

const ICONS: Record<string, string> = {
  construction: '<path d="M3 18h18M5 18V10c0-1 .5-2 2-2h10c1.5 0 2 1 2 2v8M9 8V5h6v3M8 18v-4h8v4"/><circle cx="12" cy="12" r="0.8" fill="currentColor"/>',
  healthcare: '<path d="M3 12h4l2-5 4 10 2-5h6"/>',
  fund: '<path d="M3 17l5-5 4 3 8-8M21 7v4M21 7h-4"/>',
  media: '<path d="M5 4l14 8L5 20V4z"/>',
  consumer: '<path d="M4 5h16v10H4z"/><path d="M9 19h6M12 15v4"/>',
  earlystage: '<path d="M12 22V11M7 13l5-2 5 2M9 8c0-2 1-4 3-4s3 2 3 4-2 3-3 3-3-1-3-3z"/>',
};
---

<div class="pills-row-wrap" data-pills-marquee>
  {marginalia && (
    <div class="marginalia pills-row-marginalia" set:html={marginalia} />
  )}
  <div class="pills-marquee">
    <ul class="pills-row" role="list">
      {loop.map((p, i) => {
        const isClone = i >= pills.length;
        const tipId = `pill-tip-${i}`;
        const iconSvg = p.icon && ICONS[p.icon] ? ICONS[p.icon] : ICONS.consumer;
        return (
          <li class="pill-item" aria-hidden={isClone ? 'true' : 'false'}>
            <button
              type="button"
              class="pill-chip"
              data-pill-index={i}
              aria-expanded="false"
              aria-describedby={tipId}
              tabindex={isClone ? -1 : 0}
            >
              <svg
                class="pill-icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                set:html={iconSvg}
              />
              <span class="pill-chip-label">{p.label}</span>
            </button>
            <div class="pill-tooltip" id={tipId} role="tooltip">
              <p>{p.hover}</p>
            </div>
          </li>
        );
      })}
    </ul>
  </div>
</div>

<script is:inline>
  (function () {
    const wrap = document.querySelector('[data-pills-marquee]');
    if (!wrap) return;
    const items = wrap.querySelectorAll('.pill-item');

    function closeAll(except) {
      items.forEach(function (item) {
        if (item === except) return;
        item.classList.remove('open');
        const btn = item.querySelector('.pill-chip');
        if (btn) btn.setAttribute('aria-expanded', 'false');
      });
    }

    items.forEach(function (item) {
      const btn = item.querySelector('.pill-chip');
      if (!btn) return;

      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        const isOpen = item.classList.contains('open');
        closeAll(item);
        if (isOpen) {
          item.classList.remove('open');
          btn.setAttribute('aria-expanded', 'false');
        } else {
          item.classList.add('open');
          btn.setAttribute('aria-expanded', 'true');
        }
      });

      btn.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') {
          item.classList.remove('open');
          btn.setAttribute('aria-expanded', 'false');
        }
      });
    });

    document.addEventListener('click', function (e) {
      if (!wrap.contains(e.target)) closeAll(null);
    });
  })();
</script>

---
import homeData from '@/data/home.yaml';

const { finalCta } = homeData;
---

<section class="final-cta-v5">
  <div class="final-cta-v5-inner">
    <h2 class="scroll-reveal">{finalCta.header}</h2>
    <p class="scroll-reveal">{finalCta.body}</p>
    <div class="final-cta-v5-btns scroll-reveal">
      <a class="btn btn-primary btn-lg" href={finalCta.cta_primary_href}>{finalCta.cta_primary} →</a>
      <a class="btn btn-ghost btn-lg" onclick={finalCta.cta_secondary_action} style="cursor:pointer">{finalCta.cta_secondary} →</a>
    </div>
  </div>
</section>

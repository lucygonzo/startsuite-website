---
import homeData from '@/data/home.yaml';

const { clientBand } = homeData;
const loop = [...clientBand.entries, ...clientBand.entries];

const ICONS: Record<string, string> = {
  construction: '<path d="M3 18h18M5 18V10c0-1 .5-2 2-2h10c1.5 0 2 1 2 2v8M9 8V5h6v3M8 18v-4h8v4"/>',
  healthcare: '<path d="M3 12h4l2-5 4 10 2-5h6"/>',
  fund: '<path d="M3 17l5-5 4 3 8-8M21 7v4M21 7h-4"/>',
  media: '<path d="M5 4l14 8L5 20V4z"/>',
  consumer: '<path d="M4 5h16v10H4z"/><path d="M9 19h6M12 15v4"/>',
  earlystage: '<path d="M12 22V11M7 13l5-2 5 2M9 8c0-2 1-4 3-4s3 2 3 4-2 3-3 3-3-1-3-3z"/>',
};
---

<section class="cb-wrap" aria-label="Live: rooms StartSuite is currently inside">
  <div class="cb-live-anchor" aria-hidden="true">
    <span class="cb-live-dot"></span>
    <span class="cb-live-label">Live</span>
  </div>
  <div class="cb-marquee" data-cb-marquee>
    <div class="cb-track">
      {loop.map((e, i) => {
        const isClone = i >= clientBand.entries.length;
        const iconSvg = ICONS[e.icon] || ICONS.consumer;
        return (
          <span class="cb-entry" aria-hidden={isClone ? 'true' : 'false'}>
            <svg
              class="cb-entry-icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.4"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              set:html={iconSvg}
            />
            <span class="cb-entry-size">{e.size}</span>
            <span class="cb-entry-sep" aria-hidden="true">·</span>
            <span class="cb-entry-sector">{e.sector}</span>
            <span class="cb-entry-detail">{e.detail}</span>
          </span>
        );
      })}
    </div>
  </div>
</section>

---
import homeData from '@/data/home.yaml';
import GlobeCanvas from '@/components/GlobeCanvas.astro';

const { hero } = homeData;
---

<section class="hero hero-v5">
  <div class="hero-bg-glow"></div>
  <div class="hero-inner">
    <div>
      <p class="hero-eyebrow-v5">{hero.eyebrow}</p>
      <h1 set:html={hero.headline} />
      <p class="hero-sub">{hero.subheadline}</p>
      <div class="hero-ctas">
        <a class="btn btn-primary btn-lg" href="/brand-hq">{hero.cta_primary} →</a>
        <a class="btn btn-outline btn-lg" href="/request-a-spot">{hero.cta_secondary} →</a>
      </div>
    </div>
    <GlobeCanvas />
  </div>
</section>

---
import homeData from '@/data/home.yaml';

const { vcFirm } = homeData;
---

<section class="vc-wrap section-alt">
  <div class="vc-inner">
    <div class="vc-card scroll-reveal">
      <div class="vc-eyebrow marginalia">Inside the room</div>
      <h2>{vcFirm.header}</h2>
      <div class="vc-body">
        {vcFirm.paragraphs.map((p: string) => (
          <p>{p}</p>
        ))}
      </div>
      {vcFirm.cta && (
        <a class="vc-cta" href={vcFirm.href}>{vcFirm.cta} →</a>
      )}
    </div>
  </div>
</section>

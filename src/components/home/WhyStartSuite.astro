---
import homeData from '@/data/home.yaml';

const { whyStartSuite } = homeData;
---

<div class="why-wrap">
<div class="why-inner">
  <div class="why-header scroll-reveal">
    <div>
      <div class="pill">{ whyStartSuite.pill }</div>
      <h2 set:html={whyStartSuite.headline} />
    </div>
    <p>{ whyStartSuite.subheadline }</p>
  </div>
  <div style="position:relative">
    <div class="marginalia" style="position:absolute;top:-18px;right:0">{ whyStartSuite.layout_marginalia }</div>
  </div>
  <div class="why-layout">
    {/* Left: hero card */}
    <div class="why-hero-card scroll-reveal">
      <div>
        <div class="why-hero-card-num">{ whyStartSuite.heroCard.num }</div>
        <h3>{ whyStartSuite.heroCard.title }</h3>
        <p>{ whyStartSuite.heroCard.desc }</p>
      </div>
      <div class="why-team-grid">
        {whyStartSuite.heroCard.team.map((member: any) => (
          <div class="why-team-item">
            <div class="why-team-item-name">{member.name}</div>
            <div class="why-team-item-role" set:html={member.role} />
            <div class="why-team-item-tag">{member.tag}</div>
          </div>
        ))}
      </div>
    </div>

    {/* Right: stacked cards */}
    <div class="why-right-stack">
      {whyStartSuite.rightCards.map((card: any) => (
        <div class="why-card scroll-reveal">
          <div class="why-card-num">{card.num}</div>
          <h3>{card.title}</h3>
          <p>{card.desc}</p>
          <div class="why-card-accent">{card.accent}</div>
        </div>
      ))}
    </div>
  </div>
</div>
</div>

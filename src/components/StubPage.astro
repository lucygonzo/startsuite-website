---
interface Props {
  title: string;
  blurb?: string;
}

const { title, blurb = "Coming soon. We're building this page next." } = Astro.props;
---

<section class="stub-page">
  <div class="stub-inner">
    <p class="stub-eyebrow">StartSuite</p>
    <h1>{title}</h1>
    <p class="stub-blurb">{blurb}</p>
    <div class="stub-ctas">
      <a class="btn btn-primary btn-lg" href="/">Back to home →</a>
      <a class="btn btn-outline btn-lg" href="/request-a-spot">Request a spot →</a>
    </div>
  </div>
</section>

<style>
  .stub-page{
    min-height:80vh;display:flex;align-items:center;justify-content:center;
    padding:160px 48px 100px;
  }
  .stub-inner{
    max-width:620px;text-align:center;
  }
  .stub-eyebrow{
    font-family:var(--mono);font-size:10px;font-weight:700;
    letter-spacing:0.18em;text-transform:uppercase;
    color:var(--purple-light);margin-bottom:28px;
  }
  .stub-page h1{
    font-size:clamp(40px,5.5vw,64px);
    background:linear-gradient(160deg,#fff 30%,var(--accent) 100%);
    -webkit-background-clip:text;-webkit-text-fill-color:transparent;
    background-clip:text;letter-spacing:-0.04em;line-height:1.05;
    margin-bottom:24px;
  }
  .stub-blurb{
    font-size:16px;color:var(--text-muted);line-height:1.7;
    margin-bottom:40px;
  }
  .stub-ctas{
    display:flex;gap:14px;justify-content:center;flex-wrap:wrap;
  }
  @media (max-width: 600px){
    .stub-page{padding:120px 24px 80px}
    .stub-ctas{flex-direction:column;align-items:stretch}
  }
</style>
